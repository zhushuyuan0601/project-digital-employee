\"glm-5\",\n            \"name\": \"GLM 5\",\n            \"reasoning\": true,\n            \"input\": [\"text\"],\n            \"cost\": {\"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0},\n            \"contextWindow\": 128000,\n            \"maxTokens\": 8192\n          }\n        ]\n      }\n    }\n  },\n  \"agents\": {\n    \"defaults\": {\n      \"model\": {\n        \"primary\": \"anthropic/kimi-k2.5\"\n      },\n      \"models\": {\n        \"qwen-portal/coder-model\": {\"alias\": \"qwen\"},\n        \"qwen-portal/vision-model\": {},\n        \"anthropic/kimi-k2.5\": {\"alias\": \"kimi\"}\n      },\n      \"workspace\": \"/Users/lihzz/.openclaw/workspace\",\n      \"compaction\": {\"mode\": \"safeguard\"},\n      \"maxConcurrent\": 4,\n      \"subagents\": {\"maxConcurrent\": 8}\n    }\n  },\n  \"tools\": {\"profile\": \"messaging\"},\n  \"messages\": {\"ackReactionScope\": \"group-mentions\"},\n  \"commands\": {\"native\": \"auto\", \"nativeSkills\": \"auto\", \"restart\": true, \"ownerDisplay\": \"raw\"},\n  \"session\": {\"dmScope\": \"per-channel-peer\"},\n  \"gateway\": {\n    \"port\": 18789,\n    \"mode\": \"local\",\n    \"bind\": \"loopback\",\n    \"auth\": {\"mode\": \"token\", \"token\": \"0bbfb0399fcf95bd2deefd552a2ece3f399e8bbae54920a2\"},\n    \"tailscale\": {\"mode\": \"off\", \"resetOnExit\": false}\n  },\n  \"plugins\": {\"entries\": {\"qwen-portal-auth\": {\"enabled\": true}}}\n}\n```\n\n### 一键命令（复制粘贴到终端）：\n\n```bash\ncat > ~/.openclaw/openclaw.json << 'EOF'\n{\"meta\":{\"lastTouchedVersion\":\"2026.3.2\",\"lastTouchedAt\":\"2026-03-03T05:42:23.030Z\"},\"auth\":{\"profiles\":{\"qwen-portal:default\":{\"provider\":\"qwen-portal\",\"mode\":\"oauth\"}}},\"models\":{\"providers\":{\"qwen-portal\":{\"baseUrl\":\"https://portal.qwen.ai/v1\",\"apiKey\":\"qwen-oauth\",\"api\":\"openai-completions\",\"models\":[{\"id\":\"coder-model\",\"name\":\"Qwen Coder\",\"reasoning\":false,\"input\":[\"text\"],\"cost\":{\"input\":0,\"output\":0