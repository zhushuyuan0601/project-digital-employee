{"type":"message","id":"febc1fa1","parentId":"c6440724","timestamp":"2026-03-03T18:14:29.491Z","message":{"role":"toolResult","toolCallId":"call_ccabf7044ba044a08b47ec03","toolName":"read","content":[{"type":"text","text":"        # Markdown 版本\n        md_file = self.report_dir / f\"daily-{date}.md\"\n        with open(md_file, \"w\", encoding=\"utf-8\") as f:\n            f.write(report)\n        \n        # HTML 版本（简化版）\n        html_content = self._markdown_to_html(report)\n        html_file = self.report_dir / f\"daily-{date}.html\"\n        with open(html_file, \"w\", encoding=\"utf-8\") as f:\n            f.write(html_content)\n        \n        self.log(f\"✅ 报告已保存到 {md_file}\")\n        return md_file\n    \n    def _markdown_to_html(self, markdown: str) -> str:\n        \"\"\"简单的 Markdown 转 HTML\"\"\"\n        # 简化版本，实际可使用 marked 等库\n        html = f\"\"\"<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <title>AI 前沿日报</title>\n    <style>\n        body {{ font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; }}\n        h1 {{ color: #333; }}\n        h2 {{ color: #666; border-bottom: 1px solid #eee; }}\n        .heat-high {{ color: #ff6b6b; }}\n        .heat-medium {{ color: #ffa500; }}\n        table {{ border-collapse: collapse; width: 100%; }}\n        th, td {{ border: 1px solid #ddd; padding: 8px; text-align: left; }}\n        th {{ background-color: #f5f5f5; }}\n    </style>\n</head>\n<body>\n{markdown.replace('# ', '<h1>').replace('## ', '<h2>').replace('\\n', '<br>')}\n</body>\n</html>\"\"\"\n        return html\n    \n    def send_to_feishu(self, report: str, date: str):\n        \"\"\"\n        技能 4：飞书推送（带链接 + 摘要）\n        \"\"\"\n        if not FEISHU_CONFIG.get(\"webhook_url\"):\n            self.log(\"⚠️ 飞书 Webhook 未配置，跳过推送\")\n            return False\n        \n        try:\n            # 提取 Top 3 作为摘要\n            lines = report.split(\"\\n\")\n            summary_lines = []\n            for line in lines:\n                if \"###\" in line and len(summary_lines) < 3:\n                    summary_lines.append(line.replace(\"###\", \"\").strip())\n            \n            summary = \"\\n\".join(summary_lines)\n            \n            # 构建飞书消息\n            message = {\n                \"msg_type\": \"interactive\",\n                \"card\": {\n                    \"header\": {\n                        \"title\": {\n                            \"tag\": \"plain_text\",\n                            \"content\": f\"📰 AI 前沿日报已发布 | {date}\"\n                        },\n                        \"template\": \"blue\"\n                    },\n                    \"elements\": [\n                        {\n                            \"tag\": \"markdown\",\n                            \"content\": f\"**今日热点**:\\n{summary[:300]}\\n\\n\"\n                        },\n                        {\n                            \"tag\": \"action_group\",\n                            \"actions\": [\n                                {\n                                    \"tag\": \"button\",\n                                    \"text\": {\n                                        \"tag\": \"plain_text\",\n\n[115 more lines in file. Use offset=460 to continue.]"}],"isError":false,"timestamp":1772561669464}}
