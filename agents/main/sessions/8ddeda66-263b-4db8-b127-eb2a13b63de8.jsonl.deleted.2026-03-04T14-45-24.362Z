          headers={\"Content-Type\": \"application/json\"},\n                timeout=10\n            )\n            \n            if response.status_code == 200:\n                self.log(\"✅ 简报已推送到飞书（文本格式）\")\n                return True\n            else:\n                self.log(f\"❌ 飞书推送失败：{response.status_code}\")\n                return False\n                \n        except Exception as e:\n            self.log(f\"❌ 飞书推送异常：{e}\")\n            return False","oldText":"    def send_to_feishu(self, report: str, date: str):\n        \"\"\"\n        技能 4：飞书推送（带链接 + 摘要）\n        \"\"\"\n        if not FEISHU_CONFIG.get(\"webhook_url\"):\n            self.log(\"⚠️ 飞书 Webhook 未配置，跳过推送\")\n            return False\n        \n        try:\n            # 提取 Top 3 作为摘要\n            lines = report.split(\"\\n\")\n            summary_lines = []\n            for line in lines:\n                if \"###\" in line and len(summary_lines) < 3:\n                    summary_lines.append(line.replace(\"###\", \"\").strip())\n            \n            summary = \"\\n\".join(summary_lines)\n            \n            # 构建飞书消息\n            message = {\n                \"msg_type\": \"interactive\",\n                \"card\": {\n                    \"header\": {\n                        \"title\": {\n                            \"tag\": \"plain_text\",\n                            \"content\": f\"📰 AI 前沿日报已发布 | {date}\"\n                        },\n                        \"template\": \"blue\"\n                    },\n                    \"elements\": [\n                        {\n                            \"tag\": \"markdown\",\n                            \"content\": f\"**今日热点**:\\n{summary[:300]}\\n\\n\"\n                        },\n                        {\n                            \"tag\": \"action_group\",\n                            \"actions\": [\n                                {\n                                    \"tag\": \"button\",\n                                    \"text\": {\n                                        \"tag\": \"plain_text\",\n                                        \"content\": \"📌 查看完整报告\"\n                                    },\n                                    \"url\": self._get_report_link(date),\n                                    \"type\": \"primary\",\n                                    \"value\": {}\n                                }\n                            ]\n                        },\n                        {\n                            \"tag\": \"note\",\n                            \"elements\": [\n                                {\n                                    \"tag\": \"plain_text\",\n                                    \"content\": \"—— 自动化情报系统 by OpenClaw\"\n                                }\n                            ]\n                        }\n                    ]\n                }\n            }\n            \n            import requests\n            response = requests.post(\n                FEISHU_CONFIG[\"webhook_url\"],\n                json=message,\n                headers={\"Content-Type\": \"application/json\"},\n                timeout=10\n            )\n            \n            if response.status_code == 200:\n                self.log(\"✅ 简报已推送到飞书（交互式卡片）\")\n                return True\n            else:\n                self.log(f\"❌ 飞书推送失败：{response.status_code}\")\n                return False\n                \n        except Exception as e:\n            self.log(f\"❌ 飞书推送异常：{e}\")\n            return False","path":"/Users/lihzz/openclawCompany/agents/content.py"}}],"api":"openai-completions","provider":"local-qwen2","model":"Qwen3.5-122B-A10B-FP8","usage":{"input":87047,"output":1285,"cacheRead":0,"cacheWrite":0,"totalTokens":88332,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772562434710}}
