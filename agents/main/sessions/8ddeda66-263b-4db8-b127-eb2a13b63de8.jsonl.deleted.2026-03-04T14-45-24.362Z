{"type":"message","id":"2c1e429a","parentId":"183671f3","timestamp":"2026-03-03T18:09:16.241Z","message":{"role":"toolResult","toolCallId":"call_d7b9dad3082548c690320dc0","toolName":"read","content":[{"type":"text","text":"\"\"\"\n公司配置 - 数字员工团队\n\"\"\"\nfrom pathlib import Path\nimport os\n\n# 公司根目录\nCOMPANY_DIR = Path(__file__).parent\n\n# 共享记忆目录\nSHARED_MEMORY = COMPANY_DIR / \"memory\"\nSHARED_MEMORY.mkdir(exist_ok=True)\n\n# 各角色工作目录\nROLE_DIRS = {\n    \"zoe\": COMPANY_DIR / \"agents\" / \"zoe\",\n    \"researcher\": COMPANY_DIR / \"agents\" / \"researcher\",\n    \"analyst\": COMPANY_DIR / \"agents\" / \"analyst\",\n    \"developer\": COMPANY_DIR / \"agents\" / \"developer\",\n    \"content\": COMPANY_DIR / \"agents\" / \"content\",\n    \"monitor\": COMPANY_DIR / \"agents\" / \"monitor\",\n}\n\nfor dir_path in ROLE_DIRS.values():\n    dir_path.mkdir(parents=True, exist_ok=True)\n\n# GitHub 配置\nGITHUB_CONFIG = {\n    \"username\": \"zhushuyuan0601\",\n    \"token\": os.getenv(\"GITHUB_TOKEN\", \"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\"),  # 从环境变量读取，默认值\n    \"default_visibility\": \"private\",  # private 或 public\n    \"auto_create_repo\": True,\n}\n\n# 飞书机器人配置\nFEISHU_CONFIG = {\n    \"webhook_url\": \"https://open.feishu.cn/open-apis/bot/v2/hook/f0a6a9c6-76e4-4222-9a09-b5cb1b310114\",\n    \"mention_all\": False,\n}\n\n# 邮件配置\nEMAIL_CONFIG = {\n    \"smtp_server\": \"smtp.gmail.com\",\n    \"smtp_port\": 587,\n    \"sender_email\": \"\",\n    \"sender_password\": \"\",\n}\n\n# 定时任务配置\nSCHEDULE = {\n    \"daily_briefing\": \"0 8 * * *\",  # 每天早上 8 点\n    \"hotspot_research\": \"0 9 * * *\",  # 每天早上 9 点\n    \"analysis\": \"0 10 * * *\",  # 每天早上 10 点\n    \"development\": \"0 14 * * *\",  # 每天下午 2 点\n    \"progress_check\": \"0 20 * * *\",  # 每天晚上 8 点\n}\n\n# 热点关键词\nHOTSPOT_KEYWORDS = [\n    \"大模型\",\n    \"智能体\",\n    \"AI Agent\",\n    \"LLM\",\n    \"生成式 AI\",\n    \"AIGC\",\n    \"人工智能\",\n    \"机器学习\",\n    \"深度学习\",\n]\n\n# 竞品公司列表\nCOMPETITORS = [\n    \"中国电信\",\n    \"中国移动\",\n    \"中国联通\",\n    \"百度\",\n    \"阿里\",\n    \"腾讯\",\n    \"字节跳动\",\n]\n\n# ============================================\n# 🎯 AI 技术前沿调研研究员 - 公众号清单\n# ============================================\n\n# 一、AI 技术前沿（大模型 & 智能体 Agent）\nAI_TECH_ACCOUNTS = [\n    {\"name\": \"机器之心\", \"focus\": [\"论文解读\", \"技术趋势\", \"公司动态\"]},\n    {\"name\": \"量子位\", \"focus\": [\"大模型发布\", \"融资\", \"技术突破\"]},\n    {\"name\": \"AI科技评论\", \"focus\": [\"学术会议\", \"专家访谈\", \"深度技术\"]},\n    {\"name\": \"新智元\", \"focus\": [\"AI+产业\", \"商业化\", \"Agent 应用场景\"]},\n    {\"name\": \"深度求索\", \"focus\": [\"模型更新\", \"推理优化\", \"Agent 架构\"]},\n    {\"name\": \"智谱 AI\", \"focus\": [\"GLM 技术\", \"AutoGLM\", \"API 更新\"]},\n    {\"name\": \"通义千问\", \"focus\": [\"Qwen 大模型\", \"Agent SDK\", \"工具调用\"]},\n    {\"name\": \"百度智能云技术站\", \"focus\": [\"文心一言\", \"AgentBuilder\", \"百度系 AI\"]},\n]\n\n# 二、三大运营商技术产品动态\nOPERATOR_ACCOUNTS = [\n    {\"name\": \"中国移动\", \"focus\": [\"算力网络\", \"九天 AI\", \"5G+ 工业互联网\"]},\n    {\"name\": \"中国电信\", \"focus\": [\"云网融合\", \"天翼 AI\", \"星辰大模型\"]},\n    {\"name\": \"中国联通\", \"focus\": [\"联通云\", \"鸿湖大模型\", \"AI+ 政务\"]},\n    {\"name\": \"中国移动研究院\", \"focus\": [\"技术白皮书\", \"标准进展\", \"AI in 网络\"]},\n    {\"name\": \"中国电信研究院\", \"focus\": [\"6G 预研\", \"AI 能力开放平台\"]},\n    {\"name\": \"中国联通研究院\", \"focus\": [\"鸿湖大模型\", \"边缘智能\"]},\n    {\"name\": \"天翼物联\", \"focus\": [\"AIoT\", \"感知网络\", \"智能终端\"]},\n    {\"name\": \"九天人工智能\", \"focus\": [\"九天大模型\", \"行业解决方案\"]},\n]\n\n# 三、互联网热点产品与技术趋势\nINTERNET_ACCOUNTS = [\n    {\"name\": \"晚点 LatePost\", \"focus\": [\"大厂战略\", \"AI 产品竞争\"]},\n    {\"name\": \"36 氪\", \"focus\": [\"创业公司融资\", \"新产品发布\"]},\n    {\"name\": \"虎嗅 APP\", \"focus\": [\"商业逻辑\", \"AI 产品复盘\"]},\n    {\"name\": \"极客公园\", \"focus\": [\"AI 产品体验\", \"创新设计\"]},\n    {\"name\": \"字母榜\", \"focus\": [\"大厂组织变动\", \"AI 团队动态\"]},\n    {\"name\": \"腾讯研究院\", \"focus\": [\"混元大模型\", \"社交 AI\", \"AI 伦理\"]},\n    {\"name\": \"阿里技术\", \"focus\": [\"通义千问\", \"达摩院\", \"AI 工程化\"]},\n    {\"name\": \"华为研究\", \"focus\": [\"盘古大模型\", \"AI 框架\", \"昇腾生态\"]},\n]\n\n# 四、行业市场与宏观趋势\nMARKET_ACCOUNTS = [\n    {\"name\": \"IDC 咨询\", \"focus\": [\"AI 市场份额\", \"增长率\", \"市场数据\"]},\n    {\"name\": \"艾瑞咨询\", \"focus\": [\"AI+ 教育\", \"医疗\", \"金融场景\"]},\n    {\"name\": \"头豹研究院\", \"focus\": [\"行业报告\", \"趋势图表\"]},\n    {\"name\": \"甲子光年\", \"focus\": [\"AI 基础设施\", \"Agent 创业\"]},\n    {\"name\": \"资本侦探\", \"focus\": [\"AI 初创融资\", \"估值变化\"]},\n    {\"name\": \"中国信息通信研究院\", \"focus\": [\"人工智能白皮书\", \"大模型标准\"]},\n]\n\n# 所有公众号汇总\nALL_ACCOUNTS = AI_TECH_ACCOUNTS + OPERATOR_ACCOUNTS + INTERNET_ACCOUNTS + MARKET_ACCOUNTS\n\n# 爬取策略配置\nCRAWL_STRATEGY = {\n    \"daily_accounts\": 20,  # 每日爬取前 20 个核心号\n    \"keywords_per_account\": 3,  # 每个号搜索 3 个关键词\n    \"time_range\": \"7d\",  # 最近 7 天\n    \"categories\": [\"技术突破\", \"产品发布\", \"市场动态\", \"融资事件\", \"白皮书\"],\n}\n"}],"isError":false,"timestamp":1772561356236}}
