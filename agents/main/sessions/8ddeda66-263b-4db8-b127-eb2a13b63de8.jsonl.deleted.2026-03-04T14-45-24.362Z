{"type":"message","id":"56f201a1","parentId":"5133ef3d","timestamp":"2026-03-03T18:41:47.556Z","message":{"role":"toolResult","toolCallId":"call_b8900b663f3845d9b21d03c3","toolName":"read","content":[{"type":"text","text":"#!/bin/bash\n# start.sh - AI 公司启动脚本\n\necho \"================================\"\necho \"🤖 AI 产品公司 - 启动脚本\"\necho \"================================\"\n\n# 切换到公司目录\ncd /Users/lihzz/openclawCompany\n\n# 检查 Python 环境\nif ! command -v python3 &> /dev/null; then\n    echo \"❌ 错误：未找到 Python3\"\n    exit 1\nfi\n\necho \"\"\necho \"📋 可用命令:\"\necho \"  ./start.sh dispatch    - 分发今日工作流（CEO Zoe）\"\necho \"  ./start.sh research    - 运行研究任务\"\necho \"  ./start.sh analysis    - 运行分析任务\"\necho \"  ./start.sh briefing    - 生成并发送简报\"\necho \"  ./start.sh develop     - 开始产品开发\"\necho \"  ./start.sh monitor     - 运行监控检查\"\necho \"  ./start.sh daily       - 运行完整每日流程\"\necho \"  ./start.sh setup-cron  - 设置定时任务\"\necho \"\"\n\n# 激活虚拟环境\nif [ -d \"venv\" ]; then\n    source venv/bin/activate\nfi\n\n# 执行命令\ncase \"$1\" in\n    dispatch)\n        echo \"📡 分发今日工作流...\"\n        python3 agents/zoe.py dispatch\n        ;;\n    research)\n        echo \"🔍 运行研究任务...\"\n        python3 agents/researcher.py\n        ;;\n    analysis)\n        echo \"📊 运行分析任务...\"\n        python3 agents/analyst.py\n        ;;\n    briefing)\n        echo \"📰 生成简报...\"\n        python3 agents/content.py\n        ;;\n    develop)\n        echo \"💻 开始产品开发...\"\n        python3 agents/developer.py\n        ;;\n    monitor)\n        echo \"👀 运行监控检查...\"\n        python3 agents/monitor.py\n        ;;\n    daily)\n        echo \"🚀 运行完整每日流程...\"\n        echo \"\"\n        echo \"Step 1/5: 研究热点...\"\n        python3 agents/researcher.py\n        echo \"\"\n        echo \"Step 2/5: 分析热点...\"\n        python3 agents/analyst.py\n        echo \"\"\n        echo \"Step 3/5: 生成简报...\"\n        python3 agents/content.py\n        echo \"\"\n        echo \"Step 4/5: 开始开发...\"\n        python3 agents/developer.py\n        echo \"\"\n        echo \"Step 5/5: 监控检查...\"\n        python3 agents/monitor.py\n        echo \"\"\n        echo \"✅ 每日流程完成！\"\n        ;;\n    setup-cron)\n        echo \"⏰ 设置定时任务...\"\n        ./scripts/setup_cron.sh\n        ;;\n    *)\n        echo \"用法：$0 {dispatch|research|analysis|briefing|develop|monitor|daily|setup-cron}\"\n        exit 1\n        ;;\nesac\n"}],"isError":false,"timestamp":1772563307539}}
