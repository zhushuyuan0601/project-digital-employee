{"type":"message","id":"a7c08e84","parentId":"ce46b6d2","timestamp":"2026-03-03T18:14:24.586Z","message":{"role":"toolResult","toolCallId":"call_22b6df5cf29e4fa8a5a227ac","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nContent - AI 内容主编（高级编辑 + 出版策划 + 数据分析师）\n不仅能写日报，还能：\n✅ 结构化提炼\n✅ 自动排版美化\n✅ 生成富媒体摘要页（带图、表格、链接）\n✅ 推送飞书通知 + 附可点击的精美报告\n\"\"\"\nimport json\nimport os\nimport subprocess\nimport time\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import List, Dict\nimport sys\nfrom pathlib import Path\nsys.path.insert(0, str(Path(__file__).parent.parent))\n\nfrom config import (\n    COMPANY_DIR, SHARED_MEMORY, FEISHU_CONFIG, EMAIL_CONFIG,\n    AI_TECH_ACCOUNTS, OPERATOR_ACCOUNTS, INTERNET_ACCOUNTS, MARKET_ACCOUNTS\n)\n\n\nclass AIContentEditor:\n    \"\"\"AI 内容主编 - 高级科技编辑\"\"\"\n    \n    def __init__(self):\n        self.log_file = COMPANY_DIR / \"logs\" / \"content.log\"\n        self.output_dir = COMPANY_DIR / \"output\" / \"content\"\n        self.output_dir.mkdir(parents=True, exist_ok=True)\n        \n        self.report_dir = COMPANY_DIR / \"reports\"\n        self.report_dir.mkdir(parents=True, exist_ok=True)\n        \n        # GitHub Pages 配置（可选）\n        self.github_pages_config = {\n            \"enabled\": False,  # 设置为 True 启用\n            \"username\": \"zhushuyuan0601\",\n            \"repo\": \"ai-daily-report\",\n            \"token\": os.getenv(\"GITHUB_TOKEN\", \"\"),\n        }\n    \n    def log(self, message: str):\n        \"\"\"记录日志\"\"\"\n        timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n        log_entry = f\"[{timestamp}] [AI_CONTENT_EDITOR] {message}\\n\"\n        print(log_entry.strip())\n        with open(self.log_file, \"a\") as f:\n            f.write(log_entry)\n    \n    def read_research_output(self) -> dict:\n        \"\"\"读取研究员的输出\"\"\"\n        research_file = COMPANY_DIR / \"output\" / \"research\" / f\"research_{datetime.now().strftime('%Y%m%d')}.json\"\n        if research_file.exists():\n            with open(research_file, \"r\", encoding=\"utf-8\") as f:\n                return json.load(f)\n        return {}\n    \n    def deduplicate_events(self, hotspots: List[Dict]) -> List[Dict]:\n        \"\"\"\n        技能 1：去重合并 - 识别重复事件\n        \"\"\"\n        self.log(\"🔍 开始去重合并...\")\n        \n        # 按标题相似度分组\n        event_groups = {}\n        for h in hotspots:\n            # 简化标题用于去重（提取核心关键词）\n            title = h.get(\"title\", \"\")\n            # 提取公司名作为分组 key\n            key = self._extract_company(title)\n            \n            if key not in event_groups:\n                event_groups[key] = []\n            event_groups[key].append(h)\n        \n        # 合并每组为一条\n\n[494 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1772561664578}}
