rors.append(f\"邮箱 SMTP 连接失败: {e}\")\n        print(f\"   ❌ SMTP 连接测试失败: {e}\")\nelse:\n    errors.append(\"邮箱配置不完整\")\n    print(f\"   ❌ 邮箱配置不完整\")\nprint()\n\n# 3. 验证 Tavily API\nprint(\"3️⃣ Tavily 搜索 API\")\nif TAVILY_CONFIG.get('api_key'):\n    print(f\"   ✅ API Key 已配置\")\n    print(f\"      {TAVILY_CONFIG['api_key'][:15]}...\")\n    \n    # 测试 API\n    try:\n        response = requests.post(\n            \"https://api.tavily.com/search\",\n            json={\n                \"api_key\": TAVILY_CONFIG['api_key'],\n                \"query\": \"test\",\n                \"max_results\": 1\n            },\n            timeout=10\n        )\n        if response.status_code == 200:\n            print(f\"   ✅ API 测试成功\")\n        else:\n            warnings.append(f\"Tavily API 返回状态码: {response.status_code}\")\n            print(f\"   ⚠️  API 返回状态码: {response.status_code}\")\n    except Exception as e:\n        warnings.append(f\"Tavily API 测试失败: {e}\")\n        print(f\"   ⚠️  API 测试失败: {e}\")\nelse:\n    errors.append(\"Tavily API Key 未配置\")\n    print(f\"   ❌ API Key 未配置\")\nprint()\n\n# 4. 验证 GitHub 配置\nprint(\"4️⃣ GitHub 配置\")\nif GITHUB_CONFIG.get('username') and GITHUB_CONFIG.get('token'):\n    print(f\"   ✅ GitHub 配置完整\")\n    print(f\"      用户名：{GITHUB_CONFIG['username']}\")\n    print(f\"      Token: {GITHUB_CONFIG['token'][:10]}...\")\nelse:\n    errors.append(\"GitHub 配置不完整\")\n    print(f\"   ❌ GitHub 配置不完整\")\nprint()\n\n# 5. 验证定时任务配置\nprint(\"5️⃣ 定时任务配置\")\nif SCHEDULE:\n    print(f\"   ✅ 定时任务已配置\")\n    for task, cron in SCHEDULE.items():\n        print(f\"      {task}: {cron}\")\nelse:\n    errors.append(\"定时任务未配置\")\n    print(f\"   ❌ 定时任务未配置\")\nprint()\n\n# 6. 验证目录结构\nprint(\"6️⃣ 目录结构\")\nrequired_dirs = [\n    \"agents\", \"memory\", \"output\", \"projects\", \"logs\",\n    \"dashboard\", \"data\", \"scripts\", \"config\"\n]\nfor dir_name in required_dirs:\n    dir_path = COMPANY_DIR / dir_name\n    if dir_path.exists():\n        print(f\"   ✅ {dir_name}/\")\n    else:\n        warnings.append(f\"目录不存在: {dir_name}\")\n        print(f\"   ⚠️  {dir_name}/ (不存在)\")\nprint()\n\n# 总结\nprint(\"=\" * 60)\nprint(\"📊 验证总结\")\nprint(\"=\" * 60)\n\nif errors:\n    print(f\"❌ 错误 ({len(errors)}):\")\n    for e in errors:\n        print(f\"   - {e}\")\nelse:\n    print(\"✅ 无错误\")\n\nif warnings:\n    print(f\"\\n⚠️  警告 ({len(warnings)}):\")\n    for w in warnings:\n        print(f\"   - {w}\")\nelse:\n    print(\"✅ 无警告\")\n\nprint()\nif not errors:\n    print(\"🎉 所有配置验证通过！系统已就绪！\")\n    print()\n    print(\"下一步:\")\n    print(\"   1. 运行: ./scripts/setup_cron.sh  (设置定时任务)\")\n    print(\"   2. 运行: ./start.sh daily        (测试完整流程)\")\n    print(\"   3. 打开: dashboard/index.html    (查看监控大盘)\")\n    sys.exit(0)\nelse:\n    print(\"⚠️  请修复错误后再继续\")\n    sys.exit(1)\n"}}],"api":"openai-completions","provider":"local-qwen2","model":"Qwen3.5-122B-A10B-FP8","usage":{"input":52920,"output":1507,"cacheRead":0,"cacheWrite":0,"totalTokens":54427,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772561392367}}
