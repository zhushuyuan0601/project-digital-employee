, cwd=test_project, check=True, capture_output=True)\nsubprocess.run([\"git\", \"add\", \".\"], cwd=test_project, check=True, capture_output=True)\nsubprocess.run([\"git\", \"commit\", \"-m\", \"Initial commit\"], cwd=test_project, check=True, capture_output=True)\nprint(f\"   ✅ 本地仓库初始化完成\")\nprint()\n\n# 3. 转换为安全的仓库名\nrepo_name = \"测试 AI 项目\"\nif any('\\u4e00' <= char <= '\\u9fff' for char in repo_name):\n    chinese_to_english = {\n        '互联网': 'internet',\n        '热点': 'hotspot',\n        '助手': 'assistant',\n        'AI': 'ai',\n        '运营商': 'operator',\n        '电信': 'telecom',\n        '移动': 'mobile',\n        '联通': 'unicom',\n        '测试': 'test',\n        '项目': 'project',\n    }\n    safe_repo_name = repo_name\n    for cn, en in chinese_to_english.items():\n        safe_repo_name = safe_repo_name.replace(cn, en)\n    safe_repo_name = re.sub(r'[^a-zA-Z0-9-]', '-', safe_repo_name)\n    safe_repo_name = re.sub(r'-+', '-', safe_repo_name)\n    safe_repo_name = safe_repo_name.strip('-').lower()\nelse:\n    safe_repo_name = repo_name.replace(' ', '-').lower()\n\nprint(f\"3️⃣ 仓库名转换:\")\nprint(f\"   原始：{repo_name}\")\nprint(f\"   转换：{safe_repo_name}\")\nprint()\n\n# 4. 创建 GitHub 仓库\nprint(\"4️⃣ 创建 GitHub 仓库...\")\ndata = {\"name\": safe_repo_name, \"private\": True, \"auto_init\": False}\nresponse = requests.post(\"https://api.github.com/user/repos\", headers=headers, json=data)\n\nif response.status_code in [200, 201]:\n    print(f\"   ✅ 仓库创建成功：{safe_repo_name}\")\n    remote_url = f\"https://{token}@github.com/{username}/{safe_repo_name}.git\"\nelif response.status_code == 422:\n    print(f\"   ℹ️ 仓库已存在\")\n    remote_url = f\"https://{token}@github.com/{username}/{safe_repo_name}.git\"\nelse:\n    print(f\"   ❌ 创建失败：{response.json().get('message')}\")\n    sys.exit(1)\nprint()\n\n# 5. 添加远程并推送（带错误恢复策略）\nprint(\"5️⃣ 推送到 GitHub...\")\ntry:\n    subprocess.run([\"git\", \"remote\", \"remove\", \"origin\"], cwd=test_project, capture_output=True)\nexcept:\n    pass\n\nsubprocess.run([\"git\", \"remote\", \"add\", \"origin\", remote_url], cwd=test_project, check=True, capture_output=True)\n\n# 策略 1: 先尝试 pull --rebase 同步\nprint(\"   🔍 策略 1: 尝试 pull --rebase 同步远程...\")\npull_result = subprocess.run([\"git\", \"pull\", \"--rebase\", \"origin\", \"main\"], cwd=test_project, capture_output=True, text=True)\n\nif pull_result.returncode == 0:\n    print(\"   ✅ 远程同步成功，准备推送...\")\n    push_result = subprocess.run([\"git\", \"push\", \"-u\", \"origin\", \"main\"], cwd=test_project, capture_output=True, text=True)\n    if push_result.returncode == 0:\n        print(f\"   ✅ 推送成功!\")\n        print(f\"      URL: https://github.com/{username}/{safe_repo_name}\")\n    else:\n        print(f\"   ⚠️ 推送失败：{push_result.stderr.strip().split(chr(10))[0]}\")\n        # 策略 2: 强制推送\n        print(\"   🔁 策略 2: 尝试强制推送...\")\n        push_result = subprocess.run([\"git\", \"push\", \"-u\", \"origin\", \"main\", \"--force\"], cwd=test_project, capture_output=True, text=True)\n        if push_result.returncode == 0:\n            print(f\"   ✅ 强制推送成功!\")\n            print(f\"      URL: https://github.com/{username}/{safe_repo_name}\")\n        else:\n            print(f\"   ❌ 强制推送也失败：{push_result.stderr.strip().split(chr(10))[0]}\")\n            print(f\"   💡 调试建议：检查 GITHUB_TOKEN 权限或网络连接\")\nelif \"fatal: Not a valid object name\" in pull_result.stderr or \"fatal: refusing to merge unrelated histories\" in pull_result.stderr:\n    # 远程是空的或历史不相关，直接强制推送\n    print(\"   ℹ️ 远程仓库为空或历史不相关，直接强制推送...\")\n    push_result = subprocess.run([\"git\", \"push\", \"-u\", \"origin\", \"main\", \"--force\"], cwd=test_project, capture_output=True, text=True)\n    if push_result.returncode == 0:\n        print(f\"   ✅ 推送成功!\")\n        print(f\"      URL: https://github.com/{username}/{safe_repo_name}\")\n    else:\n        print(f\"   ❌ 推送失败：{push_result.stderr.strip().split(chr(10))[0]}\")\nelse:\n    print(f\"   ⚠️ pull 失败：{pull_result.stderr.strip().split(chr(10))[0]}\")\n    # 策略 2: 强制推送\n    print(\"   🔁 策略 2: 尝试强制推送...\")\n    push_result = subprocess.run([\"git\", \"push\", \"-u\", \"origin\", \"main\", \"--force\"], cwd=test_project, capture_output=True, text=True)\n    if push_result.returncode == 0:\n        print(f\"   ✅ 强制推送成功!\")\n        print(f\"      URL: https://github.com/{username}/{safe_repo_name}\")\n    else:\n        print(f\"   ❌ 强制推送也失败：{push_result.stderr.strip().split(chr(10))[0]}\")\n        print(f\"   💡 调试建议：检查 GITHUB_TOKEN 权限或网络连接\")\n\nprint()\n\n# 6. 清理（无论成功与否都清理）\nprint(\"6️⃣ 清理测试文件...\")\nimport shutil\nshutil.rmtree(test_project, ignore_errors=True)\n\n# 强制尝试删除 GitHub 仓库\nprint(\"   🧹 正在清理远程仓库...\")\ndelete_response = requests.delete(f\"https://api.github.com/user/repos/{username}/{safe_repo_name}\", headers=headers)\nif delete_response.status_code in [204, 404]:\n    print(f\"   ✅ 测试仓库已清理（状态码：{delete_response.status_code}）\")\nelse:\n    print(f\"   ⚠️ 清理失败，状态码：{delete_response.status_code}\")\n    print(f\"   ℹ️ 请手动删除：https://github.com/{username}/{safe_repo_name}\")\n\nprint()\nprint(\"=\" * 60)\nprint(\"🎉 GitHub 推送测试完成！\")\nprint(\"=\" * 60)\n","path":"/Users/lihzz/openclawCompany/scripts/test_github_full.py"}}],"api":"openai-completions","provider":"local-qwen2","model":"Qwen3.5-122B-A10B-FP8","usage":{"input":103683,"output":2176,"cacheRead":0,"cacheWrite":0,"totalTokens":105859,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772563644950}}
