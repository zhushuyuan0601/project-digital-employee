{"type":"message","id":"e428d53b","parentId":"8fb4197c","timestamp":"2026-03-03T18:14:48.574Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在需要添加 send_email 方法的实现，在 send_to_feishu 方法后面添加邮件发送功能。\n","thinkingSignature":"reasoning"},{"type":"text","text":"\n\n"},{"type":"toolCall","id":"call_54722817f6aa45278f57fcac","name":"edit","arguments":{"newText":"    def send_to_feishu(self, report: str, date: str):\n        \"\"\"\n        技能 4：飞书推送（带链接 + 摘要）\n        \"\"\"\n        if not FEISHU_CONFIG.get(\"webhook_url\"):\n            self.log(\"⚠️ 飞书 Webhook 未配置，跳过推送\")\n            return False\n        \n        try:\n            # 提取 Top 3 作为摘要\n            lines = report.split(\"\\n\")\n            summary_lines = []\n            for line in lines:\n                if \"###\" in line and len(summary_lines) < 3:\n                    summary_lines.append(line.replace(\"###\", \"\").strip())\n            \n            summary = \"\\n\".join(summary_lines)\n            \n            # 构建飞书消息\n            message = {\n                \"msg_type\": \"interactive\",\n                \"card\": {\n                    \"header\": {\n                        \"title\": {\n                            \"tag\": \"plain_text\",\n                            \"content\": f\"📰 AI 前沿日报已发布 | {date}\"\n                        },\n                        \"template\": \"blue\"\n                    },\n                    \"elements\": [\n                        {\n                            \"tag\": \"markdown\",\n                            \"content\": f\"**今日热点**:\\n{summary[:300]}\\n\\n\"\n                        },\n                        {\n                            \"tag\": \"action_group\",\n                            \"actions\": [\n                                {\n                                    \"tag\": \"button\",\n                                    \"text\": {\n                                        \"tag\": \"plain_text\",\n                                        \"content\": \"📌 查看完整报告\"\n                                    },\n                                    \"url\": self._get_report_link(date),\n                                    \"type\": \"primary\",\n                                    \"value\": {}\n                                }\n                            ]\n                        },\n                        {\n                            \"tag\": \"note\",\n                            \"elements\": [\n                                {\n                                    \"tag\": \"plain_text\",\n                                    \"content\": \"—— 自动化情报系统 by OpenClaw\"\n                                }\n                            ]\n                        }\n                    ]\n                }\n            }\n            \n            import requests\n            response = requests.post(\n                FEISHU_CONFIG[\"webhook_url\"],\n                json=message,\n                headers={\"Content-Type\": \"application/json\"},\n                timeout=10\n            )\n            \n            if response.status_code == 200:\n                self.log(\"✅ 简报已推送到飞书（交互式卡片）\")\n                return True\n            else:\n                self.log(f\"❌ 飞书推送失败：{response.status_code}\")\n                return False\n                \n        except Exception as e:\n            self.log(f\"❌ 飞书推送异常：{e}\")\n            return False\n    \n    def send_email(self, report: str, date: str):\n        \"\"\"发送邮件简报\"\"\"\n        if not EMAIL_CONFIG.get(\"sender_email\") or not EMAIL_CONFIG.get(\"sender_password\"):\n            self.log(\"⚠️ 邮箱配置不完整，跳过邮件发送\")\n            return False\n        \n        try:\n            import smtplib\n            from email.mime.text import MIMEText\n            from email.mime.multipart import MIMEMultipart\n            \n            # 提取摘要（前 500 字）\n            summary = report[:500] + \"...\" if len(report) > 500 else report\n            \n            # 构建邮件\n            msg = MIMEMultipart()\n            msg['From'] = EMAIL_CONFIG['sender_email']\n            msg['To'] = EMAIL_CONFIG['sender_email']  # 发送到自己\n            msg['Subject'] = f\"📰 AI 前沿日报 - {date}\"\n            \n            # 邮件正文（HTML 格式）\n            html_body = f\"\"\"\n            <html>\n            <head>\n                <style>\n                    body {{ font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; }}\n                    h1 {{ color: #333; }}\n                    h2 {{ color: #666; border-bottom: 1px solid #eee; }}\n                    .hotspot {{ background: #f9f9f9; padding: 10px; margin: 10px 0; border-left: 4px solid #007bff; }}\n                    .tag {{ background: #e0e0e0; padding: 2px 8px; border-radius: 4px; font-size: 12px; }}\n                </style>\n            </head>\n            <body>\n                <h1>📰 AI 前沿日报</h1>\n                <p><strong>日期</strong>: {date}</p>\n                <hr>\n                <h2>🔥 今日热点</h2>\n                {summary.replace('\\n', '<br>')}\n                <hr>\n                <p><em>完整报告请查看附件或日志</em></p>\n                <p style=\"color: #999; font-size: 12px;\">—— 自动化情报系统 by AI Content Editor</p>\n            </body>\n            </html>\n            \"\"\"\n            \n            msg.attach(MIMEText(html_body, 'html'))\n            \n            # 发送邮件\n            server = smtplib.SMTP(EMAIL_CONFIG['smtp_server'], EMAIL_CONFIG['smtp_port'])\n            server.starttls()\n            server.login(EMAIL_CONFIG['sender_email'], EMAIL_CONFIG['sender_password'])\n            server.send_message(msg)\n            server.quit()\n            \n            self.log(\"✅ 简报已通过邮件发送\")\n            return True\n            \n        except Exception as e:\n            self.log(f\"❌ 邮件发送失败：{e}\")\n            return False","oldText":"    def send_to_feishu(self, report: str, date: str):\n        \"\"\"\n        技能 4：飞书推送（带链接 + 摘要）\n        \"\"\"\n        if not FEISHU_CONFIG.get(\"webhook_url\"):\n            self.log(\"⚠️ 飞书 Webhook 未配置，跳过推送\")\n            return False\n        \n        try:\n            # 提取 Top 3 作为摘要\n            lines = report.split(\"\\n\")\n            summary_lines = []\n            for line in lines:\n                if \"###\" in line and len(summary_lines) < 3:\n                    summary_lines.append(line.replace(\"###\", \"\").strip())\n            \n            summary = \"\\n\".join(summary_lines)\n            \n            # 构建飞书消息\n            message = {\n                \"msg_type\": \"interactive\",\n                \"card\": {\n                    \"header\": {\n                        \"title\": {\n                            \"tag\": \"plain_text\",\n                            \"content\": f\"📰 AI 前沿日报已发布 | {date}\"\n                        },\n                        \"template\": \"blue\"\n                    },\n                    \"elements\": [\n                        {\n                            \"tag\": \"markdown\",\n                            \"content\": f\"**今日热点**:\\n{summary[:300]}\\n\\n\"\n                        },\n                        {\n                            \"tag\": \"action_group\",\n                            \"actions\": [\n                                {\n                                    \"tag\": \"button\",\n                                    \"text\": {\n                                        \"tag\": \"plain_text\",\n                                        \"content\": \"📌 查看完整报告\"\n                                    },\n                                    \"url\": self._get_report_link(date),\n                                    \"type\": \"primary\",\n                                    \"value\": {}\n                                }\n                            ]\n                        },\n                        {\n                            \"tag\": \"note\",\n                            \"elements\": [\n                                {\n                                    \"tag\": \"plain_text\",\n                                    \"content\": \"—— 自动化情报系统 by OpenClaw\"\n                                }\n                            ]\n                        }\n                    ]\n                }\n            }\n            \n            import requests\n            response = requests.post(\n                FEISHU_CONFIG[\"webhook_url\"],\n                json=message,\n                headers={\"Content-Type\": \"application/json\"},\n                timeout=10\n            )\n            \n            if response.status_code == 200:\n                self.log(\"✅ 简报已推送到飞书（交互式卡片）\")\n                return True\n            else:\n                self.log(f\"❌ 飞书推送失败：{response.status_code}\")\n                return False\n                \n        except Exception as e:\n            self.log(f\"❌ 飞书推送异常：{e}\")\n            return False","path":"/Users/lihzz/openclawCompany/agents/content.py"}}],"api":"openai-completions","provider":"local-qwen2","model":"Qwen3.5-122B-A10B-FP8","usage":{"input":75961,"output":1921,"cacheRead":0,"cacheWrite":0,"totalTokens":77882,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772561675398}}
