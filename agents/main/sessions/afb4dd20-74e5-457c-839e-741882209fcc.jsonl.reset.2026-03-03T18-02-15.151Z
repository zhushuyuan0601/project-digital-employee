{"type":"message","id":"9b69f356","parentId":"a261e6c7","timestamp":"2026-03-03T15:49:35.896Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"继续创建 CEO Zoe 的主编排器代码，负责理解需求、拆解任务、调度其他 Agent。\n","thinkingSignature":"reasoning"},{"type":"text","text":"\n\n"},{"type":"toolCall","id":"call_585c608b556847e1a9537184","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nZoe - CEO（主编排器）\n负责理解需求、拆解任务、调度其他数字员工\n\"\"\"\nimport json\nimport subprocess\nimport time\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom config import COMPANY_DIR, SHARED_MEMORY, ROLE_DIRS\n\n\nclass Zoe:\n    \"\"\"CEO - 总指挥\"\"\"\n    \n    def __init__(self):\n        self.log_file = COMPANY_DIR / \"logs\" / \"zoe.log\"\n        self.task_registry = COMPANY_DIR / \"tasks.json\"\n        \n    def log(self, message: str):\n        \"\"\"记录日志\"\"\"\n        timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n        log_entry = f\"[{timestamp}] [ZOE] {message}\\n\"\n        print(log_entry.strip())\n        with open(self.log_file, \"a\") as f:\n            f.write(log_entry)\n    \n    def read_shared_memory(self, filename: str) -> str:\n        \"\"\"读取共享记忆\"\"\"\n        file_path = SHARED_MEMORY / filename\n        if file_path.exists():\n            with open(file_path, \"r\") as f:\n                return f.read()\n        return \"\"\n    \n    def write_shared_memory(self, filename: str, content: str):\n        \"\"\"写入共享记忆\"\"\"\n        file_path = SHARED_MEMORY / filename\n        with open(file_path, \"w\") as f:\n            f.write(content)\n    \n    def spawn_agent(self, role: str, task: str, context: dict = None) -> str:\n        \"\"\"\n        启动数字员工\n        使用 OpenClaw 的 sessions_spawn 机制\n        \"\"\"\n        task_id = f\"{role}-{int(time.time())}\"\n        \n        # 构建任务信息\n        task_info = {\n            \"id\": task_id,\n            \"role\": role,\n            \"task\": task,\n            \"context\": context or {},\n            \"status\": \"running\",\n            \"startedAt\": int(time.time()),\n        }\n        \n        # 保存到任务注册表\n        self._save_task(task_info)\n        \n        self.log(f\"启动 {role} 执行任务：{task[:50]}... (ID: {task_id})\")\n        \n        # 实际实现：调用 sessions_spawn 或 sessions_send\n        # 这里先记录任务，后续可以扩展为真正的多 Agent 调度\n        return task_id\n    \n    def _save_task(self, task_info: dict):\n        \"\"\"保存任务到注册表\"\"\"\n        if self.task_registry.exists():\n            with open(self.task_registry, \"r\") as f:\n                tasks = json.load(f)\n        else:\n            tasks = []\n        \n        tasks.append(task_info)\n        \n        with open(self.task_registry, \"w\") as f:\n            json.dump(tasks, f, indent=2, ensure_ascii=False)\n    \n    def dispatch_daily_workflow(self):\n        \"\"\"\n        分发每日工作流\n        \"\"\"\n        self.log(\"=\" * 50)\n        self.log(\"开始每日工作流\")\n        \n        # 1. 08:00 - Content 发送简报\n        self.log(\"【08:00】通知 Content 发送简报\")\n        self.spawn_agent(\"content\", \"生成并发送今日 AI 热点简报\", {\n            \"time\": \"08:00\",\n            \"target\": \"feishu_bot\",\n        })\n        \n        # 2. 09:00 - Researcher 爬取热点\n        self.log(\"【09:00】通知 Researcher 爬取热点\")\n        self.spawn_agent(\"researcher\", \"爬取微信公众号 AI 方向热点\", {\n            \"keywords\": [\"大模型\", \"智能体\", \"AI Agent\", \"LLM\"],\n            \"sources\": [\"weixin.qq.com\"],\n        })\n        \n        # 3. 10:00 - Analyst 分析热点\n        self.log(\"【10:00】通知 Analyst 分析热点\")\n        self.spawn_agent(\"analyst\", \"分析今日热点并进行头脑风暴\", {\n            \"input\": \"researcher_output\",\n            \"competitors\": [\"中国电信\", \"中国移动\", \"百度\", \"阿里\"],\n        })\n        \n        # 4. 14:00 - Developer 开发产品\n        self.log(\"【14:00】通知 Developer 开始开发\")\n        self.spawn_agent(\"developer\", \"开发优先级最高的热点产品\", {\n            \"priority\": 1,\n            \"type\": \"MVP\",\n        })\n        \n        # 5. 20:00 - Monitor 检查进度\n        self.log(\"【20:00】通知 Monitor 检查进度\")\n        self.spawn_agent(\"monitor\", \"检查所有任务进度并更新状态\", {\n            \"report_to\": \"zoe\",\n        })\n        \n        self.log(\"每日工作流已分发\")\n        self.log(\"=\" * 50)\n    \n    def handle_hotspot(self, hotspot_info: dict):\n        \"\"\"\n        处理新发现的热点\n        \"\"\"\n        self.log(f\"收到新热点：{hotspot_info.get('title', '未知')}\")\n        \n        # 1. 通知 Analyst 评估\n        task_id = self.spawn_agent(\"analyst\", \"评估热点产品可行性\", {\n            \"hotspot\": hotspot_info,\n            \"competitors\": [\"中国电信\", \"中国移动\"],\n        })\n        \n        # 2. 等待评估结果后分配开发\n        # 实际实现需要等待 Analyst 返回结果\n        self.log(f\"已分配评估任务：{task_id}\")\n    \n    def daily_review(self):\n        \"\"\"\n        每日复盘\n        \"\"\"\n        self.log(\"开始每日复盘\")\n        \n        # 读取今日所有任务\n        if self.task_registry.exists():\n            with open(self.task_registry, \"r\") as f:\n                tasks = json.load(f)\n            \n            completed = [t for t in tasks if t.get(\"status\") == \"completed\"]\n            failed = [t for t in tasks if t.get(\"status\") == \"failed\"]\n            \n            self.log(f\"今日完成：{len(completed)} 个任务\")\n            self.log(f\"今日失败：{len(failed)} 个任务\")\n            \n            # 写入复盘记录\n            summary = f\"\"\"\n# 每日复盘 - {datetime.now().strftime('%Y-%m-%d')}\n\n## 完成情况\n- 完成：{len(completed)}\n- 失败：{len(failed)}\n\n## 亮点\n{self._extract_highlights(completed)}\n\n## 问题\n{self._extract_issues(failed)}\n\n## 明日改进\n- 待补充\n\"\"\"\n            self.write_shared_memory(f\"review_{datetime.now().strftime('%Y-%m-%d')}.md\", summary)\n    \n    def _extract_highlights(self, completed_tasks: list) -> str:\n        \"\"\"提取亮点\"\"\"\n        if not completed_tasks:\n            return \"无\"\n        \n        highlights = []\n        for task in completed_tasks[-3:]:\n            highlights.append(f\"- {task['role']}: {task['task'][:30]}...\")\n        return \"\\n\".join(highlights)\n    \n    def _extract_issues(self, failed_tasks: list) -> str:\n        \"\"\"提取问题\"\"\"\n        if not failed_tasks:\n            return \"无\"\n        \n        issues = []\n        for task in failed_tasks:\n            issues.append(f\"- {task['role']}: {task['task'][:30]}...\")\n        return \"\\n\".join(issues)\n\n\ndef main():\n    \"\"\"命令行入口\"\"\"\n    import argparse\n    \n    parser = argparse.ArgumentParser(description=\"Zoe - AI 公司 CEO\")\n    parser.add_argument(\"command\", choices=[\"dispatch\", \"review\", \"hotspot\"], help=\"命令\")\n    parser.add_argument(\"--data\", help=\"额外数据（JSON 字符串）\")\n    \n    args = parser.parse_args()\n    \n    zoe = Zoe()\n    \n    if args.command == \"dispatch\":\n        zoe.dispatch_daily_workflow()\n    elif args.command == \"review\":\n        zoe.daily_review()\n    elif args.command == \"hotspot\":\n        if args.data:\n            hotspot = json.loads(args.data)\n            zoe.handle_hotspot(hotspot)\n        else:\n            print(\"请提供热点数据：--data '{\\\"title\\\": \\\"xxx\\\", \\\"source\\\": \\\"xxx\\\"}'\")\n\n\nif __name__ == \"__main__\":\n    main()\n","path":"/Users/lihzz/openclawCompany/agents/zoe.py"}}],"api":"openai-completions","provider":"local-qwen2","model":"Qwen3.5-122B-A10B-FP8","usage":{"input":37265,"output":1951,"cacheRead":0,"cacheWrite":0,"totalTokens":39216,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772552963159}}
