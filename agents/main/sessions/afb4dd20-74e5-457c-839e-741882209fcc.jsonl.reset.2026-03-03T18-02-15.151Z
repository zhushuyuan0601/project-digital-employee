te: '2026-03-03',\n        category: 'code',\n        name: 'AI 情报中心（上线）',\n        path: '../projects/ai-intelligence-center/',\n        size: '12 个文件',\n        description: '完整项目',\n        icon: 'fa-check-circle',\n        color: 'green'\n      },\n      {\n        agent: 'developer',\n        date: '2026-03-03',\n        category: 'code',\n        name: 'AI 政务助手项目',\n        path: '../projects/ai-government-assistant/',\n        size: '5 个文件',\n        description: '新项目启动',\n        icon: 'fa-folder',\n        color: 'green'\n      }\n    ];\n\n    // 渲染文件列表\n    function renderFiles(fileList) {\n      const container = document.getElementById('fileList');\n      container.innerHTML = '';\n\n      // 按日期分组\n      const grouped = {};\n      fileList.forEach(file => {\n        if (!grouped[file.date]) {\n          grouped[file.date] = [];\n        }\n        grouped[file.date].push(file);\n      });\n\n      // 渲染\n      Object.keys(grouped).sort().reverse().forEach(date => {\n        const dateHeader = document.createElement('div');\n        dateHeader.className = 'flex items-center space-x-2 mb-3';\n        dateHeader.innerHTML = `\n          <div class=\"w-2 h-2 bg-gray-400 rounded-full\"></div>\n          <span class=\"text-sm font-semibold text-gray-600\">${date}</span>\n          <span class=\"text-xs text-gray-400\">(${grouped[date].length}个文件)</span>\n        `;\n        container.appendChild(dateHeader);\n\n        const grid = document.createElement('div');\n        grid.className = 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6';\n\n        grouped[date].forEach(file => {\n          const card = document.createElement('div');\n          card.className = 'bg-white rounded-lg shadow-sm border p-4 hover:shadow-md transition-shadow';\n          \n          const colorClasses = {\n            blue: 'from-blue-400 to-blue-500',\n            purple: 'from-purple-400 to-purple-500',\n            indigo: 'from-indigo-400 to-indigo-500',\n            green: 'from-green-400 to-green-500'\n          };\n\n          card.innerHTML = `\n            <div class=\"flex items-start space-x-3\">\n              <div class=\"w-10 h-10 bg-gradient-to-r ${colorClasses[file.color]} rounded-lg flex items-center justify-center flex-shrink-0\">\n                <i class=\"fas ${file.icon} text-white\"></i>\n              </div>\n              <div class=\"flex-1 min-w-0\">\n                <h4 class=\"font-semibold text-gray-900 truncate\">${file.name}</h4>\n                <p class=\"text-sm text-gray-500 mt-1\">${file.description}</p>\n                <div class=\"flex items-center justify-between mt-2\">\n                  <span class=\"text-xs text-gray-400\">${file.size}</span>\n                  <a href=\"${file.path}\" target=\"_blank\" class=\"px-3 py-1 bg-${file.color}-100 text-${file.color}-700 rounded text-xs hover:bg-${file.color}-200 transition-colors\">\n                    <i class=\"fas fa-eye\"></i> 查看\n                  </a>\n                </div>\n              </div>\n            </div>\n          `;\n          grid.appendChild(card);\n        });\n\n        container.appendChild(grid);\n      });\n    }\n\n    // 过滤功能\n    function filterByAgent() {\n      const agent = document.getElementById('agentFilter').value;\n      const date = document.getElementById('dateFilter').value;\n      \n      let filtered = files;\n      \n      if (agent !== 'all') {\n        filtered = filtered.filter(f => f.agent === agent);\n      }\n      \n      if (date !== 'all') {\n        filtered = filtered.filter(f => f.date === date);\n      }\n      \n      renderFiles(filtered);\n      updateStats(filtered);\n    }\n\n    function filterByDate() {\n      filterByAgent();\n    }\n\n    // 更新统计\n    function updateStats(fileList) {\n      document.getElementById('totalFiles').textContent = fileList.length;\n      document.getElementById('researchFiles').textContent = fileList.filter(f => f.category === 'research').length;\n      document.getElementById('reportFiles').textContent = fileList.filter(f => f.category === 'report').length;\n      document.getElementById('codeFiles').textContent = fileList.filter(f => f.category === 'code').length;\n    }\n\n    // 初始化\n    renderFiles(files);\n    updateStats(files);\n  </script>\n</body>\n</html>\n"}}],"api":"openai-completions","provider":"local-qwen2","model":"Qwen3.5-122B-A10B-FP8","usage":{"input":190472,"output":4447,"cacheRead":0,"cacheWrite":0,"totalTokens":194919,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772560335641}}
