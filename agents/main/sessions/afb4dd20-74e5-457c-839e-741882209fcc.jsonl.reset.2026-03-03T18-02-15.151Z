{"type":"message","id":"14278ad8","parentId":"c28bf89e","timestamp":"2026-03-03T15:36:43.251Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建监控脚本，用于定期检查所有 Agent 的状态。\n","thinkingSignature":"reasoning"},{"type":"text","text":"\n\n创建监控脚本：\n\n"},{"type":"toolCall","id":"call_0f9f3c16a4494134a1ff8b51","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\n监控脚本 - 定期检查所有 Agent 的状态\n改进版 Ralph Loop：失败时分析原因并重试\n\"\"\"\nimport json\nimport os\nimport subprocess\nimport time\nfrom datetime import datetime\nfrom pathlib import Path\nimport smtplib\nfrom email.mime.text import MIMEText\nfrom email.mime.multipart import MIMEMultipart\n\nfrom config.config import (\n    LOGS_DIR, TASK_QUEUE_DIR, WORKTREES_DIR,\n    EMAIL_CONFIG, MONITOR_CONFIG, GIT_CONFIG\n)\n\n\nclass Monitor:\n    \"\"\"Agent 监控系统\"\"\"\n    \n    def __init__(self):\n        self.log_file = LOGS_DIR / \"monitor.log\"\n        self.completed_file = LOGS_DIR / \"completed_tasks.json\"\n        \n        # 加载已完成任务列表\n        if self.completed_file.exists():\n            with open(self.completed_file, \"r\") as f:\n                self.completed_tasks = json.load(f)\n        else:\n            self.completed_tasks = []\n    \n    def log(self, message: str):\n        \"\"\"记录日志\"\"\"\n        timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n        log_entry = f\"[{timestamp}] {message}\\n\"\n        print(log_entry.strip())\n        with open(self.log_file, \"a\") as f:\n            f.write(log_entry)\n    \n    def check_task_status(self, task_file: Path) -> dict:\n        \"\"\"检查单个任务的状态\"\"\"\n        task_id = task_file.stem\n        \n        # 读取任务信息\n        with open(task_file, \"r\") as f:\n            task_info = json.load(f)\n        \n        # 检查状态\n        status = {\n            \"id\": task_id,\n            \"status\": \"unknown\",\n            \"has_pr\": False,\n            \"ci_passed\": False,\n            \"needs_attention\": False,\n            \"error\": None,\n        }\n        \n        worktree_path = Path(task_info[\"worktree\"])\n        log_file = LOGS_DIR / f\"{task_id}.log\"\n        \n        # 1. 检查日志文件是否存在且有内容\n        if log_file.exists():\n            with open(log_file, \"r\") as f:\n                log_content = f.read()\n            \n            if \"Agent 执行完成\" in log_content:\n                status[\"status\"] = \"completed\"\n            elif \"错误\" in log_content or \"Error\" in log_content:\n                status[\"status\"] = \"failed\"\n                status[\"error\"] = log_content[-500:]  # 最后 500 字符\n            else:\n                status[\"status\"] = \"running\"\n        else:\n            status[\"status\"] = \"pending\"\n        \n        # 2. 检查是否有 PR\n        repo_path = GIT_CONFIG[\"repo_path\"]\n        if repo_path and worktree_path.exists():\n            try:\n                # 检查是否有远程分支\n                result = subprocess.run(\n                    [\"git\", \"ls-remote\", \"--heads\", \"origin\", task_id],\n                    cwd=worktree_path,\n                    capture_output=True,\n                    text=True\n                )\n                if result.returncode == 0 and result.stdout.strip():\n                    status[\"has_pr\"] = True\n            except Exception as e:\n                self.log(f\"检查 PR 失败：{e}\")\n        \n        # 3. 判断是否需要人工介入\n        if status[\"status\"] == \"failed\":\n            # 检查重试次数\n            if task_info.get(\"retryCount\", 0) < MONITOR_CONFIG[\"max_retries\"]:\n                status[\"status\"] = \"retry\"\n            else:\n                status[\"needs_attention\"] = True\n        \n        return status\n    \n    def analyze_failure(self, task_info: dict, log_content: str) -> str:\n        \"\"\"分析失败原因，生成新的 prompt\"\"\"\n        self.log(\"分析失败原因...\")\n        \n        # 简单分析：根据错误类型给出建议\n        if \"import\" in log_content.lower() or \"module not found\" in log_content.lower():\n            return \"错误：模块导入失败。请先安装依赖或检查 import 路径。\"\n        elif \"syntax\" in log_content.lower() or \"parse error\" in log_content.lower():\n            return \"错误：语法错误。请检查代码格式。\"\n        elif \"test\" in log_content.lower() and \"fail\" in log_content.lower():\n            return \"错误：测试失败。请修复测试用例或调整实现。\"\n        else:\n            return \"错误：未知错误。请检查日志并手动干预。\"\n    \n    def retry_task(self, task_info: dict, error_message: str):\n        \"\"\"重试失败的任务\"\"\"\n        task_id = task_info[\"id\"]\n        task_info[\"retryCount\"] = task_info.get(\"retryCount\", 0) + 1\n        \n        self.log(f\"重试任务 {task_id} (第 {task_info['retryCount']} 次)\")\n        \n        # 更新任务信息\n        task_file = TASK_QUEUE_DIR / f\"{task_id}.json\"\n        with open(task_file, \"w\") as f:\n            json.dump(task_info, f, indent=2)\n        \n        # 更新 prompt，加入失败原因\n        worktree_path = Path(task_info[\"worktree\"])\n        prompt_file = worktree_path / \"prompt.txt\"\n        \n        if prompt_file.exists():\n            with open(prompt_file, \"r\") as f:\n                original_prompt = f.read()\n            \n            new_prompt = f\"{original_prompt}\\n\\n# 上次执行失败\\n{error_message}\\n\\n请分析错误并重试。\"\n            \n            with open(prompt_file, \"w\") as f:\n                f.write(new_prompt)\n        \n        # 重新启动 Agent\n        from agents.zoe import Zoe\n        zoe = Zoe()\n        zoe._run_claude_code(\n            task_id,\n            {\"name\": f\"重试：{task_info.get('name', '未知任务')}\", \"type\": task_info.get(\"type\", \"backend\")},\n            worktree_path,\n            task_info.get(\"agent\", \"codex\")\n        )\n    \n    def mark_completed(self, task_id: str):\n        \"\"\"标记任务完成\"\"\"\n        if task_id not in self.completed_tasks:\n            self.completed_tasks.append(task_id)\n            with open(self.completed_file, \"w\") as f:\n                json.dump(self.completed_tasks, f, indent=2)\n    \n    def check_all_tasks(self):\n        \"\"\"检查所有任务的状态\"\"\"\n        self.log(\"=\" * 50)\n        self.log(\"开始检查任务状态\")\n        \n        tasks_to_check = list(TASK_QUEUE_DIR.glob(\"*.json\"))\n        pending_tasks = []\n        completed_tasks = []\n        failed_tasks = []\n        \n        for task_file in tasks_to_check:\n            task_id = task_file.stem\n            \n            # 跳过已完成的\n            if task_id in self.completed_tasks:\n                continue\n            \n            status = self.check_task_status(task_file)\n            \n            if status[\"status\"] == \"completed\":\n                completed_tasks.append(task_id)\n                self.mark_completed(task_id)\n            elif status[\"status\"] in [\"failed\", \"retry\"]:\n                failed_tasks.append((task_id, status))\n                if status[\"status\"] == \"retry\":\n                    with open(task_file, \"r\") as f:\n                        task_info = json.load(f)\n                    self.retry_task(task_info, status.get(\"error\", \"未知错误\"))\n            else:\n                pending_tasks.append(task_id)\n        \n        # 发送通知\n        if completed_tasks or failed_tasks:\n            self.send_notification(completed_tasks, failed_tasks)\n        \n        self.log(f\"检查完成：{len(completed_tasks)} 完成，{len(failed_tasks)} 失败，{len(pending_tasks)} 进行中\")\n        self.log(\"=\" * 50)\n    \n    def send_notification(self, completed: list, failed: list):\n        \"\"\"发送邮件通知\"\"\"\n        if not EMAIL_CONFIG[\"sender_email\"]:\n            return\n        \n        subject_parts = []\n        body_parts = []\n        \n        if completed:\n            subject_parts.append(f\"✅ {len(completed)} 个任务完成\")\n            body_parts.append(\"已完成的任务：\")\n            for task_id in completed:\n                body_parts.append(f\"  - {task_id}\")\n            body_parts.append(\"\")\n        \n        if failed:\n            subject_parts.append(f\"❌ {len(failed)} 个任务失败\")\n            body_parts.append(\"失败的任务：\")\n            for task_id, status in failed:\n                if status[\"needs_attention\"]:\n                    body_parts.append(f\"  - {task_id} (需要人工介入)\")\n                else:\n                    body_parts.append(f\"  - {task_id} (正在重试)\")\n        \n        if subject_parts:\n            subject = \"[Agent 集群] \" + \" | \".join(subject_parts)\n            body = \"\\n\".join(body_parts)\n            \n            try:\n                msg = MIMEMultipart()\n                msg[\"From\"] = EMAIL_CONFIG[\"sender_email\"]\n                msg[\"To\"] = EMAIL_CONFIG[\"recipient_email\"]\n                msg[\"Subject\"] = subject\n                msg.attach(MIMEText(body, \"plain\"))\n                \n                server = smtplib.SMTP(EMAIL_CONFIG[\"smtp_server\"], EMAIL_CONFIG[\"smtp_port\"])\n                server.starttls()\n                server.login(EMAIL_CONFIG[\"sender_email\"], EMAIL_CONFIG[\"sender_password\"])\n                server.send_message(msg)\n                server.quit()\n                \n                self.log(\"监控通知已发送\")\n            except Exception as e:\n                self.log(f\"发送邮件失败：{e}\")\n    \n    def cleanup_old_worktrees(self):\n        \"\"\"清理旧的 worktree\"\"\"\n        self.log(\"清理旧的 worktree...\")\n        \n        # 保留最近 7 天的\n        cutoff_time = time.time() - (7 * 24 * 60 * 60)\n        \n        for worktree_dir in WORKTREES_DIR.iterdir():\n            if worktree_dir.is_dir():\n                mtime = worktree_dir.stat().st_mtime\n                if mtime < cutoff_time:\n                    try:\n                        import shutil\n                        shutil.rmtree(worktree_dir)\n                        self.log(f\"清理旧 worktree: {worktree_dir.name}\")\n                    except Exception as e:\n                        self.log(f\"清理失败 {worktree_dir.name}: {e}\")\n\n\ndef main():\n    \"\"\"命令行入口\"\"\"\n    monitor = Monitor()\n    monitor.check_all_tasks()\n    monitor.cleanup_old_worktrees()\n\n\nif __name__ == \"__main__\":\n    main()\n","path":"/Users/lihzz/openclawCode/agents/monitor.py"}}],"api":"openai-completions","provider":"local-qwen2","model":"Qwen3.5-122B-A10B-FP8","usage":{"input":24583,"output":2382,"cacheRead":0,"cacheWrite":0,"totalTokens":26965,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772552187480}}
