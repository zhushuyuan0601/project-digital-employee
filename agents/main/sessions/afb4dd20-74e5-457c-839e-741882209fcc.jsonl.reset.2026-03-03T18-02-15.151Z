{"type":"message","id":"80ef381c","parentId":"f47e5549","timestamp":"2026-03-03T15:50:12.252Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"继续创建 Content 角色，负责生成简报和飞书推送。\n","thinkingSignature":"reasoning"},{"type":"text","text":"\n\n"},{"type":"toolCall","id":"call_2ae61fffbcfd48f9952981f5","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nContent - 内容官\n负责生成简报、撰写报告、飞书推送\n\"\"\"\nimport json\nimport smtplib\nfrom datetime import datetime\nfrom email.mime.text import MIMEText\nfrom email.mime.multipart import MIMEMultipart\nfrom pathlib import Path\n\nfrom config import COMPANY_DIR, SHARED_MEMORY, FEISHU_CONFIG, EMAIL_CONFIG\n\n\nclass Content:\n    \"\"\"内容官 - 简报与报告\"\"\"\n    \n    def __init__(self):\n        self.log_file = COMPANY_DIR / \"logs\" / \"content.log\"\n        self.output_dir = COMPANY_DIR / \"output\" / \"content\"\n        self.output_dir.mkdir(parents=True, exist_ok=True)\n    \n    def log(self, message: str):\n        \"\"\"记录日志\"\"\"\n        timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n        log_entry = f\"[{timestamp}] [CONTENT] {message}\\n\"\n        print(log_entry.strip())\n        with open(self.log_file, \"a\") as f:\n            f.write(log_entry)\n    \n    def read_research_output(self) -> dict:\n        \"\"\"读取研究输出\"\"\"\n        research_file = COMPANY_DIR / \"output\" / \"research\" / f\"research_{datetime.now().strftime('%Y%m%d')}.json\"\n        if research_file.exists():\n            with open(research_file, \"r\") as f:\n                return json.load(f)\n        return {}\n    \n    def generate_daily_briefing(self, research: dict) -> str:\n        \"\"\"生成每日简报\"\"\"\n        self.log(\"生成每日简报\")\n        \n        hotspots = research.get(\"hotspots\", [])\n        competitors = research.get(\"competitors\", {})\n        \n        briefing = f\"\"\"\n# 🤖 AI 热点日报 - {datetime.now().strftime('%Y年%m月%d日')}\n\n---\n\n## 🔥 今日热点 TOP 5\n\n\"\"\"\n        for i, hotspot in enumerate(hotspots[:5], 1):\n            briefing += f\"\"\"\n### {i}. {hotspot['title']}\n- **来源**: {hotspot['source']}\n- **摘要**: {hotspot['summary']}\n- **标签**: {' | '.join(hotspot.get('tags', []))}\n- **链接**: [{hotspot['url']}]({hotspot['url']})\n\n\"\"\"\n        \n        briefing += \"\"\"\n---\n\n## 🏢 竞品动态\n\n\"\"\"\n        for company, info in list(competitors.items())[:3]:\n            briefing += f\"- **{company}**: {info.get('summary', '暂无更新')}\\n\"\n        \n        briefing += \"\"\"\n---\n\n## 💡 今日洞察\n\n1. **大模型应用**持续火热，垂直场景成为新战场\n2. **智能体 AI** 从概念走向落地，编排层成为关键\n3. **竞品布局** 电信运营商加速 AI 客服产品化\n\n---\n\n*本报告由 AI 公司自动生成 | 明日 8:00 准时推送*\n\"\"\"\n        \n        return briefing\n    \n    def save_briefing(self, briefing: str):\n        \"\"\"保存简报\"\"\"\n        output_file = self.output_dir / f\"briefing_{datetime.now().strftime('%Y%m%d')}.md\"\n        with open(output_file, \"w\") as encoding=\"utf-8\") as f:\n            f.write(briefing)\n        \n        self.log(f\"简报已保存到 {output_file}\")\n        return output_file\n    \n    def send_to_feishu(self, briefing: str):\n        \"\"\"发送到飞书机器人\"\"\"\n        if not FEISHU_CONFIG.get(\"webhook_url\"):\n            self.log(\"⚠️ 飞书 Webhook 未配置，跳过推送\")\n            return False\n        \n        try:\n            # 构建飞书消息格式\n            message = {\n                \"msg_type\": \"post\",\n                \"content\": {\n                    \"post\": {\n                        \"zh_cn\": {\n                            \"title\": \"🤖 AI 热点日报\",\n                            \"content\": [\n                                [\n                                    {\n                                        \"tag\": \"text\",\n                                        \"text\": briefing[:2000]  # 飞书限制\n                                    }\n                                ]\n                            ]\n                        }\n                    }\n                }\n            }\n            \n            import requests\n            response = requests.post(\n                FEISHU_CONFIG[\"webhook_url\"],\n                json=message,\n                headers={\"Content-Type\": \"application/json\"}\n            )\n            \n            if response.status_code == 200:\n                self.log(\"✅ 简报已推送到飞书\")\n                return True\n            else:\n                self.log(f\"❌ 飞书推送失败：{response.text}\")\n                return False\n                \n        except Exception as e:\n            self.log(f\"❌ 飞书推送异常：{e}\")\n            return False\n    \n    def send_email(self, briefing: str, subject: str = \"AI 热点日报\"):\n        \"\"\"发送邮件\"\"\"\n        if not EMAIL_CONFIG.get(\"sender_email\"):\n            self.log(\"⚠️ 邮件配置未设置，跳过发送\")\n            return False\n        \n        try:\n            msg = MIMEMultipart()\n            msg[\"From\"] = EMAIL_CONFIG[\"sender_email\"]\n            msg[\"To\"] = EMAIL_CONFIG.get(\"recipient_email\", EMAIL_CONFIG[\"sender_email\"])\n            msg[\"Subject\"] = subject\n            \n            msg.attach(MIMEText(briefing, \"plain\", \"utf-8\"))\n            \n            server = smtplib.SMTP(EMAIL_CONFIG[\"smtp_server\"], EMAIL_CONFIG[\"smtp_port\"])\n            server.starttls()\n            server.login(EMAIL_CONFIG[\"sender_email\"], EMAIL_CONFIG[\"sender_password\"])\n            server.send_message(msg)\n            server.quit()\n            \n            self.log(\"✅ 简报邮件已发送\")\n            return True\n            \n        except Exception as e:\n            self.log(f\"❌ 邮件发送失败：{e}\")\n            return False\n    \n    def run_daily_briefing(self):\n        \"\"\"运行每日简报任务\"\"\"\n        self.log(\"=\" * 50)\n        self.log(\"开始生成每日简报\")\n        \n        # 1. 读取研究输出\n        research = self.read_research_output()\n        if not research:\n            self.log(\"⚠️ 未找到研究输出，使用默认内容\")\n            research = {\"hotspots\": [], \"competitors\": {}}\n        \n        # 2. 生成简报\n        briefing = self.generate_daily_briefing(research)\n        \n        # 3. 保存简报\n        self.save_briefing(briefing)\n        \n        # 4. 发送到飞书\n        self.send_to_feishu(briefing)\n        \n        # 5. 发送邮件（可选）\n        # self.send_email(briefing)\n        \n        self.log(\"每日简报任务完成\")\n        self.log(\"=\" * 50)\n        \n        return briefing\n\n\ndef main():\n    \"\"\"命令行入口\"\"\"\n    content = Content()\n    content.run_daily_briefing()\n\n\nif __name__ == \"__main__\":\n    main()\n","path":"/Users/lihzz/openclawCompany/agents/content.py"}}],"api":"openai-completions","provider":"local-qwen2","model":"Qwen3.5-122B-A10B-FP8","usage":{"input":42804,"output":1616,"cacheRead":0,"cacheWrite":0,"totalTokens":44420,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772552999954}}
