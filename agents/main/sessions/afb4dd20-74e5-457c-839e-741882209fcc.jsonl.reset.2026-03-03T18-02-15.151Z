Date()\" class=\"px-4 py-2 border rounded-lg\">\n            <option value=\"all\">所有日期</option>\n            <option value=\"2026-03-01\">2026-03-01</option>\n            <option value=\"2026-03-02\">2026-03-02</option>\n            <option value=\"2026-03-03\">2026-03-03</option>\n          </select>\n        </div>\n      </div>\n    </div>\n  </nav>\n\n  <div class=\"max-w-7xl mx-auto px-4 py-6\">\n    <!-- 文件统计 -->\n    <div class=\"grid grid-cols-4 gap-4 mb-8\">\n      <div class=\"bg-white rounded-xl shadow-sm p-4 border\">\n        <p class=\"text-sm text-gray-500\">总文件数</p>\n        <p class=\"text-2xl font-bold text-gray-900\" id=\"totalFiles\">0</p>\n      </div>\n      <div class=\"bg-white rounded-xl shadow-sm p-4 border\">\n        <p class=\"text-sm text-gray-500\">研究报告</p>\n        <p class=\"text-2xl font-bold text-blue-600\" id=\"researchFiles\">0</p>\n      </div>\n      <div class=\"bg-white rounded-xl shadow-sm p-4 border\">\n        <p class=\"text-sm text-gray-500\">日报报告</p>\n        <p class=\"text-2xl font-bold text-purple-600\" id=\"reportFiles\">0</p>\n      </div>\n      <div class=\"bg-white rounded-xl shadow-sm p-4 border\">\n        <p class=\"text-sm text-gray-500\">代码文件</p>\n        <p class=\"text-2xl font-bold text-green-600\" id=\"codeFiles\">0</p>\n      </div>\n    </div>\n\n    <!-- 文件列表 -->\n    <div id=\"fileList\" class=\"space-y-4\">\n      <!-- 动态生成 -->\n    </div>\n  </div>\n\n  <script>\n    // 文件数据\n    const files = [\n      // 研究员产出\n      {\n        agent: 'researcher',\n        date: '2026-03-01',\n        category: 'research',\n        name: 'research_20260301.json',\n        path: '../output/research/research_20260301.json',\n        size: '45 KB',\n        description: '原始研究数据（115 条热点）',\n        icon: 'fa-database',\n        color: 'blue'\n      },\n      {\n        agent: 'researcher',\n        date: '2026-03-01',\n        category: 'research',\n        name: 'today_research_summary_20260301.md',\n        path: