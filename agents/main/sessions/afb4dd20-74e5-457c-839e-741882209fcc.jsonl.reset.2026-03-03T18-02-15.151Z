 \n+183             # 提交\n+184             subprocess.run([\"git\", \"commit\", \"-m\", f\"Initial commit: {repo_name}\"], cwd=project_path, check=True, capture_output=True)\n+185             \n+186             # 创建远程仓库（使用 GitHub API）\n+187             import requests\n+188             headers = {\n+189                 \"Authorization\": f\"token {token}\",\n+190                 \"Accept\": \"application/vnd.github.v3+json\"\n+191             }\n+192             \n+193             # 检查仓库是否已存在\n+194             repo_url = f\"https://api.github.com/user/repos\"\n+195             data = {\n+196                 \"name\": repo_name,\n+197                 \"private\": (visibility == \"private\"),\n+198                 \"auto_init\": True\n+199             }\n+200             \n+201             response = requests.post(repo_url, headers=headers, json=data)\n+202             \n+203             if response.status_code in [200, 201]:\n+204                 self.log(f\"✅ GitHub 仓库创建成功：{repo_name}\")\n+205                 remote_url = f\"https://{token}@github.com/{username}/{repo_name}.git\"\n+206             elif response.status_code == 422:\n+207                 self.log(f\"ℹ️ 仓库已存在，使用现有仓库：{repo_name}\")\n+208                 remote_url = f\"https://github.com/{username}/{repo_name}.git\"\n+209             else:\n+210                 self.log(f\"❌ 创建仓库失败：{response.text}\")\n+211                 return\n+212             \n+213             # 添加远程\n+214             subprocess.run([\"git\", \"remote\", \"add\", \"origin\", remote_url], cwd=project_path, check=True, capture_output=True)\n+215             \n+216             # 推送\n+217             subprocess.run([\"git\", \"push\", \"-u\", \"origin\", \"main\"], cwd=project_path, check=True, capture_output=True)\n+218             \n+219             self.log(f\"✅ 已成功推送到 GitHub: https://github.com/{username}/{repo_name}\")\n+220             \n+221         except subprocess.CalledProcessError as e:\n+222             self.log(f\"❌ Git 操作失败：{e}\")\n+223         except Exception as e:\n+224             self.log(f\"❌ GitHub 推送失败：{e}\")\n+225     \n 156     def run_daily_development(self):\n 157         \"\"\"运行每日开发任务\"\"\"\n 158         self.log(\"=\" * 50)\n 159         self.log(\"开始每日开发任务\")\n     ...","firstChangedLine":155},"isError":false,"timestamp":1772553794377}}
