{"type":"message","id":"c4dc30e4","parentId":"b8a5fa5f","timestamp":"2026-03-03T15:49:23.143Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"继续创建团队配置文件，定义每个数字员工的具体职责和配置。\n","thinkingSignature":"reasoning"},{"type":"text","text":"\n\n"},{"type":"toolCall","id":"call_79fb10b887be4aa0bbccd1e6","name":"write","arguments":{"content":"\"\"\"\n公司配置 - 数字员工团队\n\"\"\"\nfrom pathlib import Path\n\n# 公司根目录\nCOMPANY_DIR = Path(__file__).parent\n\n# 共享记忆目录\nSHARED_MEMORY = COMPANY_DIR / \"memory\"\nSHARED_MEMORY.mkdir(exist_ok=True)\n\n# 各角色工作目录\nROLE_DIRS = {\n    \"zoe\": COMPANY_DIR / \"agents\" / \"zoe\",\n    \"researcher\": COMPANY_DIR / \"agents\" / \"researcher\",\n    \"analyst\": COMPANY_DIR / \"agents\" / \"analyst\",\n    \"developer\": COMPANY_DIR / \"agents\" / \"developer\",\n    \"content\": COMPANY_DIR / \"agents\" / \"content\",\n    \"monitor\": COMPANY_DIR / \"agents\" / \"monitor\",\n}\n\nfor dir_path in ROLE_DIRS.values():\n    dir_path.mkdir(parents=True, exist_ok=True)\n\n# 飞书机器人配置\nFEISHU_CONFIG = {\n    \"webhook_url\": \"\",  # 填写飞书机器人 Webhook\n    \"mention_all\": False,\n}\n\n# 邮件配置\nEMAIL_CONFIG = {\n    \"smtp_server\": \"smtp.gmail.com\",\n    \"smtp_port\": 587,\n    \"sender_email\": \"\",\n    \"sender_password\": \"\",\n}\n\n# 定时任务配置\nSCHEDULE = {\n    \"daily_briefing\": \"0 8 * * *\",  # 每天早上 8 点\n    \"hotspot_research\": \"0 9 * * *\",  # 每天早上 9 点\n    \"analysis\": \"0 10 * * *\",  # 每天早上 10 点\n    \"development\": \"0 14 * * *\",  # 每天下午 2 点\n    \"progress_check\": \"0 20 * * *\",  # 每天晚上 8 点\n}\n\n# 热点关键词\nHOTSPOT_KEYWORDS = [\n    \"大模型\",\n    \"智能体\",\n    \"AI Agent\",\n    \"LLM\",\n    \"生成式 AI\",\n    \"AIGC\",\n    \"人工智能\",\n    \"机器学习\",\n    \"深度学习\",\n]\n\n# 竞品公司列表\nCOMPETITORS = [\n    \"中国电信\",\n    \"中国移动\",\n    \"中国联通\",\n    \"百度\",\n    \"阿里\",\n    \"腾讯\",\n    \"字节跳动\",\n]\n","path":"/Users/lihzz/openclawCompany/config.py"}}],"api":"openai-completions","provider":"local-qwen2","model":"Qwen3.5-122B-A10B-FP8","usage":{"input":36639,"output":591,"cacheRead":0,"cacheWrite":0,"totalTokens":37230,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772552958569}}
