{"type":"message","id":"6f6d2204","parentId":"03045687","timestamp":"2026-03-03T16:25:47.163Z","message":{"role":"toolResult","toolCallId":"call_81ec9e9e50714597af29f224","toolName":"read","content":[{"type":"text","text":"        \"\"\"推送到 GitHub\"\"\"\n        username = GITHUB_CONFIG.get(\"username\", \"zhushuyuan0601\")\n        token = GITHUB_CONFIG.get(\"token\", \"\")\n        visibility = GITHUB_CONFIG.get(\"default_visibility\", \"private\")\n        \n        if not token:\n            self.log(\"⚠️ GitHub Token 未配置，跳过推送\")\n            return\n        \n        try:\n            self.log(f\"开始推送到 GitHub: {username}/{repo_name}\")\n            \n            # 初始化 Git 仓库\n            subprocess.run([\"git\", \"init\"], cwd=project_path, check=True, capture_output=True)\n            subprocess.run([\"git\", \"checkout\", \"-b\", \"main\"], cwd=project_path, check=True, capture_output=True)\n            \n            # 配置用户\n            subprocess.run([\"git\", \"config\", \"user.name\", username], cwd=project_path, check=True, capture_output=True)\n            subprocess.run([\"git\", \"config\", \"user.email\", f\"{username}@users.noreply.github.com\"], cwd=project_path, check=True, capture_output=True)\n            \n            # 添加所有文件\n            subprocess.run([\"git\", \"add\", \".\"], cwd=project_path, check=True, capture_output=True)\n            \n            # 提交\n            subprocess.run([\"git\", \"commit\", \"-m\", f\"Initial commit: {repo_name}\"], cwd=project_path, check=True, capture_output=True)\n            \n            # 创建远程仓库（使用 GitHub API）\n            import requests\n            headers = {\n                \"Authorization\": f\"token {token}\",\n                \"Accept\": \"application/vnd.github.v3+json\"\n            }\n            \n            # 检查仓库是否已存在\n            repo_url = f\"https://api.github.com/user/repos\"\n            data = {\n                \"name\": repo_name,\n                \"private\": (visibility == \"private\"),\n                \"auto_init\": False  # 不自动初始化，避免冲突\n            }\n            \n            response = requests.post(repo_url, headers=headers, json=data)\n            \n            if response.status_code in [200, 201]:\n                self.log(f\"✅ GitHub 仓库创建成功：{repo_name}\")\n                remote_url = f\"https://{token}@github.com/{username}/{repo_name}.git\"\n            elif response.status_code == 422:\n                self.log(f\"ℹ️ 仓库已存在，使用现有仓库：{repo_name}\")\n                remote_url = f\"https://github.com/{username}/{repo_name}.git\"\n            else:\n                self.log(f\"❌ 创建仓库失败：{response.text}\")\n                return\n            \n            # 添加远程\n            subprocess.run([\"git\", \"remote\", \"add\", \"origin\", remote_url], cwd=project_path, check=True, capture_output=True)\n            \n            # 推送\n            subprocess.run([\"git\", \"push\", \"-u\", \"origin\", \"main\"], cwd=project_path, check=True, capture_output=True)\n            \n            self.log(f\"✅ 已成功推送到 GitHub: https://github.com/{username}/{repo_name}\")\n\n[48 more lines in file. Use offset=220 to continue.]"}],"isError":false,"timestamp":1772555147139}}
