{"type":"message","id":"dffd9952","parentId":"071fc1ac","timestamp":"2026-03-03T15:50:34.261Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"继续创建 Monitor 角色，负责定时检查任务进度和系统状态。\n","thinkingSignature":"reasoning"},{"type":"text","text":"\n\n"},{"type":"toolCall","id":"call_a57dcc66e37d452aa5b397ed","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nMonitor - 监控员\n负责定时检查任务进度、更新状态、发送警报\n\"\"\"\nimport json\nimport time\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom config import COMPANY_DIR, SHARED_MEMORY\n\n\nclass Monitor:\n    \"\"\"监控员 - 任务监控与状态更新\"\"\"\n    \n    def __init__(self):\n        self.log_file = COMPANY_DIR / \"logs\" / \"monitor.log\"\n        self.task_registry = COMPANY_DIR / \"tasks.json\"\n    \n    def log(self, message: str):\n        \"\"\"记录日志\"\"\"\n        timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n        log_entry = f\"[{timestamp}] [MONITOR] {message}\\n\"\n        print(log_entry.strip())\n        with open(self.log_file, \"a\") as f:\n            f.write(log_entry)\n    \n    def check_task_status(self) -> list:\n        \"\"\"检查所有任务状态\"\"\"\n        if not self.task_registry.exists():\n            self.log(\"未找到任务注册表\")\n            return []\n        \n        with open(self.task_registry, \"r\") as f:\n            tasks = json.load(f)\n        \n        status_report = []\n        for task in tasks:\n            # 检查任务状态（实际实现需要检查 Agent 进程、文件等）\n            task_status = {\n                \"id\": task[\"id\"],\n                \"role\": task[\"role\"],\n                \"task\": task[\"task\"][:50] + \"...\",\n                \"status\": task.get(\"status\", \"unknown\"),\n                \"startedAt\": task.get(\"startedAt\", 0),\n                \"duration\": int(time.time()) - task.get(\"startedAt\", 0),\n            }\n            status_report.append(task_status)\n        \n        return status_report\n    \n    def generate_status_report(self, tasks: list) -> str:\n        \"\"\"生成状态报告\"\"\"\n        report = f\"\"\"\n# 任务状态报告 - {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n\n## 概览\n- 总任务数：{len(tasks)}\n- 进行中：{len([t for t in tasks if t.get('status') == 'running'])}\n- 已完成：{len([t for t in tasks if t.get('status') == 'completed'])}\n- 失败：{len([t for t in tasks if t.get('status') == 'failed'])}\n\n## 任务详情\n\"\"\"\n        for task in tasks:\n            status_emoji = {\n                \"running\": \"🟡\",\n                \"completed\": \"✅\",\n                \"failed\": \"❌\",\n                \"unknown\": \"⚪\",\n            }.get(task.get(\"status\", \"unknown\"), \"⚪\")\n            \n            report += f\"\\n{status_emoji} **{task['role']}**: {task['task'][:40]}...\\n\"\n            report += f\"   状态：{task.get('status', 'unknown')}\\n\"\n            report += f\"   运行时间：{task.get('duration', 0)} 秒\\n\"\n        \n        return report\n    \n    def update_project_status(self):\n        \"\"\"更新项目状态文件\"\"\"\n        # 读取 projects 目录\n        projects_dir = COMPANY_DIR / \"projects\"\n        if not projects_dir.exists():\n            return\n        \n        projects = []\n        for project_dir in projects_dir.iterdir():\n            if project_dir.is_dir():\n                readme = project_dir / \"README.md\"\n                if readme.exists():\n                    projects.append({\n                        \"name\": project_dir.name,\n                        \"path\": str(project_dir),\n                        \"updated\": datetime.fromtimestamp(project_dir.stat().st_mtime).isoformat(),\n                    })\n        \n        # 更新 PROJECT_STATUS.md\n        status_file = COMPANY_DIR / \"PROJECT_STATUS.md\"\n        with open(status_file, \"r\") as f:\n            content = f.read()\n        \n        # 插入项目列表\n        project_list = \"\\n\".join([f\"- {p['name']}\" for p in projects]) if projects else \"- 无进行中项目\"\n        \n        # 简单替换（实际可以更智能）\n        if \"## 进行中项目\" not in content:\n            content += f\"\\n\\n## 进行中项目\\n{project_list}\"\n        \n        with open(status_file, \"w\") as f:\n            f.write(content)\n        \n        self.log(\"项目状态已更新\")\n    \n    def check_alerts(self, tasks: list) -> list:\n        \"\"\"检查需要警报的情况\"\"\"\n        alerts = []\n        \n        for task in tasks:\n            # 检查失败任务\n            if task.get(\"status\") == \"failed\":\n                alerts.append({\n                    \"type\": \"failure\",\n                    \"task\": task[\"id\"],\n                    \"message\": f\"{task['role']} 任务失败：{task['task'][:30]}...\",\n                })\n            \n            # 检查超时任务（运行超过 2 小时）\n            if task.get(\"status\") == \"running\":\n                duration = task.get(\"duration\", 0)\n                if duration > 7200:  # 2 小时\n                    alerts.append({\n                        \"type\": \"timeout\",\n                        \"task\": task[\"id\"],\n                        \"message\": f\"{task['role']} 任务运行超时：{duration // 60} 分钟\",\n                    })\n        \n        return alerts\n    \n    def send_alert(self, alerts: list):\n        \"\"\"发送警报（可以集成飞书/邮件）\"\"\"\n        if not alerts:\n            return\n        \n        self.log(f\"⚠️ 有 {len(alerts)} 个警报需要处理\")\n        \n        for alert in alerts:\n            self.log(f\"  - [{alert['type']}] {alert['message']}\")\n        \n        # 实际实现：调用飞书或邮件发送\n        # self.send_to_feishu(alerts)\n    \n    def run_periodic_check(self):\n        \"\"\"运行周期性检查\"\"\"\n        self.log(\"=\" * 50)\n        self.log(\"开始周期性检查\")\n        \n        # 1. 检查任务状态\n        tasks = self.check_task_status()\n        \n        # 2. 生成状态报告\n        report = self.generate_status_report(tasks)\n        \n        # 3. 更新项目状态\n        self.update_project_status()\n        \n        # 4. 检查警报\n        alerts = self.check_alerts(tasks)\n        self.send_alert(alerts)\n        \n        # 5. 保存报告\n        report_file = COMPANY_DIR / \"output\" / \"monitor\" / f\"status_{datetime.now().strftime('%Y%m%d_%H%M')}.md\"\n        report_file.parent.mkdir(parents=True, exist_ok=True)\n        with open(report_file, \"w\") as f:\n            f.write(report)\n        \n        self.log(f\"状态报告已保存到 {report_file}\")\n        self.log(\"周期性检查完成\")\n        self.log(\"=\" * 50)\n        \n        return {\n            \"tasks\": tasks,\n            \"alerts\": alerts,\n            \"report_file\": str(report_file),\n        }\n\n\ndef main():\n    \"\"\"命令行入口\"\"\"\n    monitor = Monitor()\n    monitor.run_periodic_check()\n\n\nif __name__ == \"__main__\":\n    main()\n","path":"/Users/lihzz/openclawCompany/agents/monitor.py"}}],"api":"openai-completions","provider":"local-qwen2","model":"Qwen3.5-122B-A10B-FP8","usage":{"input":45943,"output":1685,"cacheRead":0,"cacheWrite":0,"totalTokens":47628,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772553022594}}
