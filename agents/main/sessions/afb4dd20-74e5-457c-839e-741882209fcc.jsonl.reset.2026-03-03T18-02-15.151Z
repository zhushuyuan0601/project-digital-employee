{"type":"message","id":"143e458e","parentId":"0cf58337","timestamp":"2026-03-03T15:36:22.143Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"配置文件创建成功。现在让我创建主编排器 Zoe 的核心脚本。\n","thinkingSignature":"reasoning"},{"type":"text","text":"\n\n"},{"type":"toolCall","id":"call_14937e0237ab4f72ac4e2286","name":"write","arguments":{"path":"/Users/lihzz/openclawCode/agents/zoe.py","content":"#!/usr/bin/env python3\n\"\"\"\nZoe - 主编排器\n负责理解需求、拆解任务、调度 Agent、监控进度\n\"\"\"\nimport json\nimport os\nimport subprocess\nimport time\nimport uuid\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Optional\nimport smtplib\nfrom email.mime.text import MIMEText\nfrom email.mime.multipart import MIMEMultipart\n\nfrom config.config import (\n    BASE_DIR, WORKTREES_DIR, LOGS_DIR, TASK_QUEUE_DIR,\n    MEETING_NOTES_DIR, CLAUDE_CODE_COMMAND, EMAIL_CONFIG,\n    MONITOR_CONFIG, AGENT_STRATEGIES, GIT_CONFIG\n)\n\n\nclass Zoe:\n    \"\"\"主编排器 - 理解需求并调度 Agent\"\"\"\n    \n    def __init__(self):\n        self.task_counter = 0\n        self.log_file = LOGS_DIR / \"zoe.log\"\n        \n    def log(self, message: str):\n        \"\"\"记录日志\"\"\"\n        timestamp = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n        log_entry = f\"[{timestamp}] {message}\\n\"\n        print(log_entry.strip())\n        with open(self.log_file, \"a\") as f:\n            f.write(log_entry)\n    \n    def read_meeting_notes(self, date: Optional[str] = None) -> str:\n        \"\"\"读取会议记录\"\"\"\n        if date is None:\n            date = datetime.now().strftime(\"%Y-%m-%d\")\n        \n        note_file = MEETING_NOTES_DIR / f\"{date}.md\"\n        if note_file.exists():\n            with open(note_file, \"r\") as f:\n                return f.read()\n        return \"\"\n    \n    def parse_requirement(self, requirement: str) -> dict:\n        \"\"\"\n        解析用户需求，拆解成任务\n        实际项目中这里可以调用 LLM 来智能拆解\n        \"\"\"\n        self.log(f\"解析需求：{requirement}\")\n        \n        # 简单示例：根据关键词拆解\n        tasks = []\n        \n        if \"模板\" in requirement or \"配置\" in requirement:\n            tasks = [\n                {\"name\": \"设计数据库模型\", \"type\": \"backend\", \"priority\": \"high\"},\n                {\"name\": \"实现 API 接口\", \"type\": \"backend\", \"priority\": \"high\"},\n                {\"name\": \"创建前端 UI\", \"type\": \"frontend\", \"priority\": \"medium\"},\n                {\"name\": \"编写测试用例\", \"type\": \"backend\", \"priority\": \"high\"},\n            ]\n        elif \"bug\" in requirement.lower() or \"错误\" in requirement:\n            tasks = [\n                {\"name\": \"分析错误日志\", \"type\": \"bugfix\", \"priority\": \"high\"},\n                {\"name\": \"修复代码\", \"type\": \"backend\", \"priority\": \"high\"},\n                {\"name\": \"验证修复\", \"type\": \"backend\", \"priority\": \"high\"},\n            ]\n        else:\n            tasks = [\n                {\"name\": \"实现功能\", \"type\": \"backend\", \"priority\": \"high\"},\n                {\"name\": \"编写测试\", \"type\": \"backend\", \"priority\": \"medium\"},\n            ]\n        \n        return {\"tasks\": tasks, \"requirement\": requirement}\n    \n    def select_agent(self, task_type: str) -> str:\n        \"\"\"根据任务类型选择 Agent\"\"\"\n        strategy = AGENT_STRATEGIES.get(task_type, {\"agent\": \"codex\"})\n        return strategy[\"agent\"]\n    \n    def create_worktree(self, branch_name: str) -> Path:\n        \"\"\"创建 git worktree\"\"\"\n        worktree_path = WORKTREES_DIR / branch_name\n        repo_path = GIT_CONFIG[\"repo_path\"]\n        \n        if not repo_path:\n            self.log(f\"警告：未配置 repo_path，跳过 git worktree 创建\")\n            return worktree_path\n        \n        try:\n            # 创建 worktree\n            subprocess.run(\n                [\"git\", \"worktree\", \"add\", str(worktree_path), \"-b\", branch_name, \"origin/main\"],\n                cwd=repo_path,\n                check=True,\n                capture_output=True\n            )\n            self.log(f\"创建 worktree: {worktree_path}\")\n        except subprocess.CalledProcessError as e:\n            self.log(f\"创建 worktree 失败：{e}\")\n            # 如果分支已存在，使用现有路径\n            if not worktree_path.exists():\n                worktree_path.mkdir(parents=True, exist_ok=True)\n        \n        return worktree_path\n    \n    def start_agent(self, task_id: str, task: dict, worktree_path: Path):\n        \"\"\"启动 Agent 执行任务\"\"\"\n        agent_type = self.select_agent(task[\"type\"])\n        \n        task_info = {\n            \"id\": task_id,\n            \"name\": task[\"name\"],\n            \"type\": task[\"type\"],\n            \"agent\": agent_type,\n            \"worktree\": str(worktree_path),\n            \"branch\": task_id,\n            \"status\": \"running\",\n            \"startedAt\": int(time.time()),\n            \"retryCount\": 0,\n        }\n        \n        # 保存任务信息\n        task_file = TASK_QUEUE_DIR / f\"{task_id}.json\"\n        with open(task_file, \"w\") as f:\n            json.dump(task_info, f, indent=2)\n        \n        self.log(f\"启动 Agent [{agent_type}] 执行任务：{task['name']} (ID: {task_id})\")\n        \n        # 启动 Claude Code 作为后台进程\n        self._run_claude_code(task_id, task, worktree_path, agent_type)\n    \n    def _run_claude_code(self, task_id: str, task: dict, worktree_path: Path, agent_type: str):\n        \"\"\"运行 Claude Code\"\"\"\n        # 构建 prompt\n        prompt = self._build_prompt(task)\n        \n        # 写入 prompt 文件\n        prompt_file = worktree_path / \"prompt.txt\"\n        with open(prompt_file, \"w\") as f:\n            f.write(prompt)\n        \n        # 构建命令\n        script_path = BASE_DIR / \"scripts\" / \"run_agent.sh\"\n        cmd = [str(script_path), task_id, str(worktree_path), agent_type]\n        \n        # 启动后台进程\n        try:\n            subprocess.Popen(\n                cmd,\n                stdout=LOGS_DIR / f\"{task_id}.log\",\n                stderr=LOGS_DIR / f\"{task_id}.err.log\",\n                cwd=str(worktree_path)\n            )\n            self.log(f\"Agent 进程已启动，日志：{LOGS_DIR}/{task_id}.log\")\n        except Exception as e:\n            self.log(f\"启动 Agent 失败：{e}\")\n    \n    def _build_prompt(self, task: dict) -> str:\n        \"\"\"构建 Agent 的 prompt\"\"\"\n        meeting_notes = self.read_meeting_notes()\n        \n        prompt = f\"\"\"\n# 任务说明\n\n## 任务名称\n{task['name']}\n\n## 任务类型\n{task['type']}\n\n## 任务优先级\n{task.get('priority', 'medium')}\n\n## 业务上下文\n请阅读以下会议记录，理解业务背景：\n\n{meeting_notes if meeting_notes else \"无会议记录\"}\n\n## 要求\n1. 按照最佳实践编写代码\n2. 添加适当的测试\n3. 确保代码通过 lint 检查\n4. 完成后创建 PR\n\n## 注意事项\n- 保持代码清晰、可维护\n- 遵循项目现有代码风格\n- 如有不确定的地方，记录在 TODO 文件中\n\"\"\"\n        return prompt\n    \n    def send_email_notification(self, subject: str, body: str):\n        \"\"\"发送邮件通知\"\"\"\n        if not EMAIL_CONFIG[\"sender_email\"]:\n            self.log(\"警告：未配置邮件发送，跳过通知\")\n            return\n        \n        try:\n            msg = MIMEMultipart()\n            msg[\"From\"] = EMAIL_CONFIG[\"sender_email\"]\n            msg[\"To\"] = EMAIL_CONFIG[\"recipient_email\"]\n            msg[\"Subject\"] = f\"[Agent Cluster] {subject}\"\n            \n            msg.attach(MIMEText(body, \"plain\"))\n            \n            server = smtplib.SMTP(EMAIL_CONFIG[\"smtp_server\"], EMAIL_CONFIG[\"smtp_port\"])\n            server.starttls()\n            server.login(EMAIL_CONFIG[\"sender_email\"], EMAIL_CONFIG[\"sender_password\"])\n            server.send_message(msg)\n            server.quit()\n            \n            self.log(f\"邮件通知已发送：{subject}\")\n        except Exception as e:\n            self.log(f\"发送邮件失败：{e}\")\n    \n    def process_requirement(self, requirement: str):\n        \"\"\"\n        主流程：处理用户需求\n        \"\"\"\n        self.log(\"=\" * 50)\n        self.log(f\"开始处理新需求\")\n        \n        # 1. 解析需求\n        parsed = self.parse_requirement(requirement)\n        \n        # 2. 为每个任务创建 worktree 并启动 Agent\n        for task in parsed[\"tasks\"]:\n            self.task_counter += 1\n            task_id = f\"task-{self.task_counter:04d}-{uuid.uuid4().hex[:8]}\"\n            \n            worktree_path = self.create_worktree(task_id)\n            self.start_agent(task_id, task, worktree_path)\n        \n        # 3. 发送通知\n        self.send_email_notification(\n            \"新任务已启动\",\n            f\"已创建 {len(parsed['tasks'])} 个任务，请查看日志了解进度。\"\n        )\n        \n        self.log(\"需求处理完成\")\n        self.log(\"=\" * 50)\n\n\ndef main():\n    \"\"\"命令行入口\"\"\"\n    import argparse\n    \n    parser = argparse.ArgumentParser(description=\"Zoe - Agent 主编排器\")\n    parser.add_argument(\"requirement\", nargs=\"?\", help=\"任务需求描述\")\n    parser.add_argument(\"--file\", \"-f\", help=\"从文件读取需求\")\n    \n    args = parser.parse_args()\n    \n    zoe = Zoe()\n    \n    if args.file:\n        with open(args.file, \"r\") as f:\n            requirement = f.read()\n    elif args.requirement:\n        requirement = args.requirement\n    else:\n        requirement = input(\"请输入需求描述：\")\n    \n    zoe.process_requirement(requirement)\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"openai-completions","provider":"local-qwen2","model":"Qwen3.5-122B-A10B-FP8","usage":{"input":21369,"output":2349,"cacheRead":0,"cacheWrite":0,"totalTokens":23718,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772552167284}}
