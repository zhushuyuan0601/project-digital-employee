ss=\"form-range\"\n              />\n              <span class=\"range-value\">{{ (temperature / 100).toFixed(2) }}</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <h2>初始消息（可选）</h2>\n        <textarea\n          v-model=\"initialMessage\"\n          class=\"form-textarea\"\n          placeholder=\"如果你想发送一条初始消息，可以在这里输入...\"\n          rows=\"4\"\n        ></textarea>\n      </div>\n\n      <div class=\"actions\">\n        <button class=\"btn-secondary\" @click=\"goBack\">\n          取消\n        </button>\n        <button\n          class=\"btn-primary\"\n          @click=\"createSession\"\n          :disabled=\"!selectedAgent\"\n        >\n          创建会话\n        </button>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted } from 'vue'\nimport { useRouter, useRoute } from 'vue-router'\n\nconst router = useRouter()\nconst route = useRoute()\n\nconst selectedAgent = ref('')\nconst sessionName = ref('')\nconst selectedModel = ref('glm-5')\nconst temperature = ref(70)\nconst initialMessage = ref('')\n\nconst agents = ref([\n  { id: 'main', name: 'Main（主智能体）', model: 'glm-5', icon: '👤' },\n  { id: 'ceo', name: 'Zoe（总助理）', model: 'glm-5', icon: '👩‍💼' },\n  { id: 'researcher', name: '情报研究员', model: 'glm-5', icon: '🔍' },\n  { id: 'pm', name: 'Sarah（产品经理）', model: 'glm-5', icon: '📋' },\n  { id: 'tech-lead', name: 'Alex（技术总监）', model: 'glm-5', icon: '💻' },\n  { id: 'moyan', name: '墨言（材料撰写）', model: 'qwen-local2', icon: '✍️' },\n  { id: 'weice', name: '纬策（解决方案）', model: 'qwen-local3', icon: '🎯' },\n  { id: 'yuanzhan', name: '元栈（全栈研发）', model: 'qwen-local3', icon: '🚀' },\n  { id: 'lanji', name: '览迹（知识库）', model: 'qwen-local2', icon: '📚' }\n])\n\nconst models = ref([\n  { id: 'glm-5', name: 'GLM-5' },\n  { id: 'qwen-local2', name: 'Qwen3.5-122B (Local)' },\n  { id: 'qwen-local3', name: 'GLM-4.7-FP8 (Local)' }\n])\n\nconst selectAgent = (agentId) => {\n  const agent = agents.value.find(a => a.id === agentId)\n  selectedAgent.value = agentId\n  if (agent && !sessionName.value) {\n    sessionName.value = agent.name\n  }\n  selectedModel.value = agent ? agent.model : 'glm-5'\n}\n\nconst goBack = () => {\n  router.back()\n}\n\nconst createSession = () => {\n  if (!selectedAgent.value) return\n\n  const sessionKey = `agent:${selectedAgent.value}:main`\n\n  // 跳转到会话页面\n  router.push({\n    name: 'session-view',\n    params: { id: sessionKey }\n  })\n}\n\nonMounted(() => {\n  // 从查询参数获取预设的 agent\n  const agentId = route.query.agent\n  if (agentId && agents.value.find(a => a.id === agentId)) {\n    selectAgent(agentId)\n  }\n})\n</script>\n\n<style scoped>\n.session-create {\n  max-width: 900px;\n  margin: 0 auto;\n}\n\n.page-header {\n  margin-bottom: 32px;\n}\n\n.page-header h1 {\n  font-size: 28px;\n  font-weight: 700;\n  color: white;\n  margin: 0;\n}\n\n.create-content {\n  display: flex;\n  flex-direction: column;\n  gap: 32px;\n}\n\n.section {\n  background: rgba(255, 255, 255, 0.08);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 16px;\n  padding: 24px;\n}\n\n.section h2 {\n  font-size: 18px;\n  font-weight: 600;\n  color: white;\n  margin: 0 0 20px 0;\n}\n\n.agents-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));\n  gap: 16px;\n}\n\n.agent-card {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 12px;\n  padding: 20px;\n  background: rgba(255, 255, 255, 0.05);\n  border: 2px solid rgba(255, 255, 255, 0.1);\n  border-radius: 12px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n\n.agent-card:hover {\n  background: rgba(255, 255, 255, 0.1);\n  transform: translateY(-2px);\n}\n\n.agent-card.selected {\n  border-color: #E60012;\n  background: rgba(230, 0, 18, 0.1);\n  box-shadow: 0 4px 20px rgba(230, 0, 18, 0.2);\n}\n\n.agent-card .agent-icon {\n  font-size: 32px;\n}\n\n.agent-card .agent-name {\n  font-size: 14px;\n  font-weight: 600;\n  color: 