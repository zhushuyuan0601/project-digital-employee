px;\n        font-weight: 500;\n        letter-spacing: 2px;\n      }\n      .loading-subtext {\n        margin-top: 8px;\n        color: rgba(255, 255, 255, 0.7);\n        font-size: 14px;\n      }\n    </style>\n  </head>\n  <body>\n    <div id=\"loading\">\n      <div class=\"loading-spinner\"></div>\n      <div class=\"loading-text\">OpenClaw 控制台</div>\n      <div class=\"loading-subtext\">中国联通风格</div>\n    </div>\n    <div id=\"app\"></div>\n    <script type=\"module\" src=\"/src/main.js\"></script>\n  </body>\n</html>","path":"/Users/lihzz/.openclaw/workspace/unicom-ui/index.html"}}],"api":"openai-completions","provider":"local-qwen3","model":"GLM-4.7-FP8","usage":{"input":66347,"output":666,"cacheRead":0,"cacheWrite":0,"totalTokens":67013,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772763874264}}
