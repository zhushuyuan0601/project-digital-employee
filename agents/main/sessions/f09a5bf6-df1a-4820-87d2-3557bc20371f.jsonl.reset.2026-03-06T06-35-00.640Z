message\">{{ log.message }}</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed } from 'vue'\n\nconst loading = ref(false)\nconst searchQuery = ref('')\nconst logLevel = ref('')\nconst logSource = ref('')\n\nconst logs = ref([\n  { time: '2026-03-06 13:40:23', level: 'info', source: 'gateway', message: 'Gateway started on port 18789' },\n  { time: '2026-03-06 13:41:15', level: 'info', source: 'agent', message: 'Agent \"ceo\" connected' },\n  { time: '2026-03-06 13:42:30', level: 'warn', source: 'tool', message: 'Command execution timeout' },\n  { time: '2026-03-06 13:43:00', level: 'info', source: 'gateway', message: 'New session created' },\n  { time: '2026-03-06 13:44:12', level: 'error', source: 'gateway', message: 'Failed to connect to agent' }\n])\n\nconst filteredLogs = computed(() => {\n  return logs.value.filter(log => {\n    const matchesSearch = !searchQuery.value ||\n      log.message.toLowerCase().includes(searchQuery.value.toLowerCase())\n    const matchesLevel = !logLevel.value || log.level === logLevel.value\n    const matchesSource = !logSource.value || log.source === logSource.value\n    return matchesSearch && matchesLevel && matchesSource\n  })\n})\n\nconst refreshLogs = () => {\n  loading.value = true\n  setTimeout(() => {\n    loading.value = false\n  }, 500)\n}\n\nconst clearLogs = () => {\n  if (confirm('确定要清空所有日志吗？')) {\n    logs.value = []\n  }\n}\n</script>\n\n<style scoped>\n.logs {\n  max-width: 1400px;\n  margin: 0 auto;\n}\n\n.page-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 24px;\n}\n\n.page-header h1 {\n  font-size: 28px;\n  font-weight: 700;\n  color: white;\n  margin: 0;\n}\n\n.header-actions {\n  display: flex;\n  gap: 12px;\n  align-items: center;\n}\n\n.search-input {\n  padding: 10px 16px;\n  background: rgba(255, 255, 255, 0.08);\n  border: 1px solid rgba(255, 255, 255, 0.15);\n  border-radius: 8px;\n  color: