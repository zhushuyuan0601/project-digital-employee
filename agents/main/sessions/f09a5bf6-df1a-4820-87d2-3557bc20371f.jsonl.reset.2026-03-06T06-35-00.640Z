n class=\"btn-tool\" @click=\"toggleThinking\" title=\"思考模式\" :class=\"{ active: thinkingEnabled }\">\n              🧠\n            </button>\n          </div>\n          <div class=\"chat-input\">\n            <textarea\n              v-model=\"inputMessage\"\n              placeholder=\"输入消息... (Shift+Enter 换行)\"\n              @keydown=\"handleKeydown\"\n              ref=\"inputRef\"\n              rows=\"1\"\n            ></textarea>\n            <button\n              :class=\"['btn-send', { disabled: !inputMessage.trim() || isSending }]\"\n              @click=\"sendMessage\"\n              :disabled=\"!inputMessage.trim() || isSending\"\n            >\n              <span v-if=\"isSending\">⏳</span>\n              <span v-else>发送</span>\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, reactive, computed, onMounted, nextTick } from 'vue'\nimport { useRoute, useRouter } from 'vue-router'\n\nconst route = useRoute()\nconst router = useRouter()\n\nconst inputMessage = ref('')\nconst isSending = ref(false)\nconst thinkingEnabled = ref(false)\nconst messages = ref([])\n\n// 引用\nconst messagesContainer = ref(null)\nconst inputRef = ref(null)\n\n// 方法\nconst handleKeydown = (e) => {\n  if (e.key === 'Enter' && !e.shiftKey) {\n    e.preventDefault()\n    sendMessage()\n  }\n}\n\nconst sendMessage = async () => {\n  if (!inputMessage.value.trim() || isSending.value) return\n\n  const content = inputMessage.value.trim()\n  inputMessage.value = ''\n\n  // 添加用户消息\n  messages.value.push({\n    role: 'user',\n    content,\n    time: new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })\n  })\n\n  scrollToBottom()\n\n  // 发送消息到 Gateway\n  isSending.value = true\n  try {\n    // TODO: 连接到真实的 Gateway API\n    // const response = await fetch('/api/session/send', { ... })\n\n    // 模拟 AI 响应\n    await new Promise(resolve => setTimeout(resolve, 1000))\n\n    messages.value.push({\n      role: 'assistant',\n      content: `收到消息：${content}\\n\\n这是一个模拟响应。实际使用时会连接到 OpenClaw Gateway API 获取真实的 AI 回复。\\n\\n支持的功能：\\n• 工具调用（exec, read, write, etc.）\\n• 文件操作\\n• 代码执行\\n• Web 搜索\\n• 等等...`,\n      sender: '助手',\n      icon: '🤖',\n      time: new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })\n    })\n  } catch (error) {\n    console.error('发送消息失败:', error)\n    messages.value.push({\n      role: 'assistant',\n      content: '❌ 发送失败：' + error.message,\n      sender: '系统',\n      icon: '⚠️',\n      time: new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })\n    })\n  } finally {\n    isSending.value = false\n    scrollToBottom()\n  }\n}\n\nconst scrollToBottom = () => {\n  nextTick(() => {\n    if (messagesContainer.value) {\n      messagesContainer.value.scrollTop = messagesContainer.value.scrollHeight\n    }\n  })\n}\n\nconst formatMessage = (content) => {\n  return content\n    .replace(/\\n/g, '<br>')\n    .replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>')\n    .replace(/`([^`]+)`/g, '<code class=\"inline-code\">$1</code>')\n    .replace(/```([\\s\\S]*?)```/g, '<pre class=\"code-block\"><code>$1</code></pre>')\n}\n\nconst attachFile = () => {\n  console.log('Attach file')\n  // TODO: 实现文件上传\n}\n\nconst voiceInput = () => {\n  console.log('Voice input')\n  // TODO: 实现语音输入\n}\n\nconst insertCode = () => {\n  inputMessage.value += '\\n```\\n\\n```\\n'\n  inputRef.value?.focus()\n}\n\nconst toggleThinking = () => {\n  thinkingEnabled.value = !thinkingEnabled.value\n}\n\nonMounted(() => {\n  // 从路由参数获取会话信息\n  const sessionKey = route.params.id || route.query.session\n  console.log('Session key:', sessionKey)\n\n  // 添加欢迎消息\n  messages.value.push({\n    role: 'assistant',\n    content: `你好！欢迎来到 OpenClaw 聊天界面 🎉\\n\\n当前会话：${sessionKey || '默认'}\\n\\n我可以帮你：\\n• 执行命令和脚本\\n• 读写文件\\n• 搜索信息\\n• 分析代码\\n• 等等...\\n\\n请发送消息开始对话！`,\n    sender: 'OpenClaw',\n    icon: '🤖',\n    time: new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })\n  })\n\n  if (inputRef.value) {\n    inputRef.value.focus()\n  }\n})\n</script>\n\n<style scoped>\n.chat-page {\n  height: 100%;\n  display: flex;\n  flex-direction: column;\n}\n\n.chat-container {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  height: 100%;\n  background: rgba(0, 0, 0, 0.2);\n  border-radius: 12px;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  overflow: hidden;\n}\n\n.chat-main {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n}\n\n.chat-messages {\n  flex: 1;\n  overflow-y: auto;\n  padding: 24px;\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n}\n\n.message {\n  display: flex;\n  gap: 12px;\n  max-width: 900px;\n  animation: slideIn 0.3s ease-out;\n}\n\n@keyframes slideIn {\n  from {\n    opacity: 0;\n    transform: translateY(10px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.message.user {\n  flex-direction: row-reverse;\n  align-self: flex-end;\n}\n\n.message-avatar {\n  width: 36px;\n  height: 36px;\n  border-radius: 10px;\n  background: linear-gradient(135deg, #E60012, #ff3366);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n  box-shadow: 0 2px 8px rgba(230, 0, 18, 0.3);\n}\n\n.avatar-icon {\n  font-size: 20px;\n}\n\n.message-content {\n  flex: 1;\n  min-width: 0;\n}\n\n.message-header {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  margin-bottom: 8px;\n}\n\n.message-sender {\n  font-size: 13px;\n  font-weight: 600;\n  color: rgba(255, 255, 255, 0.9);\n}\n\n.message-time {\n  font-size: 12px;\n  color: rgba(255, 255, 255, 0.5);\n}\n\n.message-text {\n  padding: 16px 20px;\n  border-radius: 16px;\n  background: rgba(255, 255, 255, 0.1);\n  color: rgba(255, 255, 255, 0.95);\n  line-height: 1.6;\n  font-size: 15px;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  word-wrap: break-word;\n}\n\n.message.user .message-text {\n  background: linear-gradient(135deg, #E60012, #ff3366);\n  border: none;\n}\n\n.message-text :deep(inline) {\n  background: rgba(0, 0, 0, 0.3);\n  padding: 2px 6px;\n  border-radius: 4px;\n  font-size: 14px;\n  font-family: monospace;\n}\n\n.message-text :deep(.code-block) {\n  background: rgba(0, 0, 0, 0.4);\n  padding: 16px;\n  border-radius: 8px;\n  margin: 12px 0;\n  overflow-x: auto;\n}\n\n.message-text :deep(.code-block code) {\n  font-family: monospace;\n  font-size: 13px;\n  line-height: 1.6;\n  color: #fff;\n}\n\n.tool-calls {\n  margin-top: 12px;\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.tool-call {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  padding: 8px 12px;\n  background: rgba(0, 0, 0, 0.3);\n  border-radius: 6px;\n  font-size: 13px;\n}\n\n.tool-icon {\n  font-size: 14px;\n}\n\n.tool-name {\n  font-family: monospace;\n  color: rgba(255, 255, 255, 0.9);\n}\n\n/* 输入区域 */\n.chat-input-container {\n  padding: 16px 24px;\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n  background: rgba(0, 0, 0, 0.2);\n}\n\n.chat-toolbar {\n  display: flex;\n  gap: 8px;\n  margin-bottom: 12px;\n}\n\n.btn-tool {\n  padding: 8px 12px;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  background: rgba(255, 255, 255, 0.05);\n  border-radius: 8px;\n  color: rgba(255, 255, 255, 0.7);\n  font-size: 16px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n\n.btn-tool:hover {\n  background: rgba(255, 255, 255, 0.1);\n  color: white;\n  transform: translateY(-2px);\n}\n\n.btn-tool.active {\n  background: rgba(230, 0, 18, 0.2);\n  border-color: rgba(230, 0, 18, 0.4);\n  color: #E60012;\n}\n\n.chat-input {\n  display: flex;\n  gap: 12px;\n  align-items: flex-end;\n}\n\n.chat-input textarea {\n  flex: 1;\n  min-height: 60px;\n  max-height: 200px;\n  padding: 14px 18px;\n  background: rgba(255, 255, 255, 0.08);\n  border: 1px solid rgba(255, 255, 255, 0.15);\n  border-radius: 16px;\n  color: white;\n  font-size: 15px;\n  line-height: 1.6;\n  resize: none;\n  