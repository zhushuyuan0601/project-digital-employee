>\n            </div>\n          </div>\n        </div>\n        <div class=\"session-actions\">\n          <button class=\"btn-icon\" @click=\"deleteSession(session.key)\" title=\"删除\">\n            🗑️\n          </button>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted } from 'vue'\nimport { useRouter } from 'vue-router'\n\nconst router = useRouter()\nconst loading = ref(false)\nconst searchQuery = ref('')\nconst filterAgent = ref('')\n\nconst agents = ref([\n  { id: 'main', name: 'Main' },\n  { id: 'ceo', name: 'Zoe' },\n  { id: 'researcher', name: '研究员' },\n  { id: 'pm', name: 'Sarah' },\n  { id: 'tech-lead', name: 'Alex' }\n])\n\nconst sessions = ref([\n  {\n    key: 'agent:main:main',\n    title: '主会话',\n    preview: '你好，有什么可以帮你的吗？',\n    agent: 'Main',\n    agentId: 'main',\n    icon: '👤',\n    time: '刚刚',\n    active: true,\n    unread: 0\n  },\n  {\n    key: 'agent:ceo:main',\n    title: '项目讨论',\n    preview: '讨论 OpenClaw 前端优化项目',\n    agent: 'Zoe',\n    agentId: 'ceo',\n    icon: '👩‍💼',\n    time: '10分钟前',\n    active: false,\n    unread: 3\n  },\n  {\n    key: 'agent:researcher:main',\n    title: '研究报告',\n    preview: '核聚变能源现状调研报告',\n    agent: '研究员',\n    agentId: 'researcher',\n    icon: '🔍',\n    time: '1小时前',\n    active: false,\n    unread: 0\n  }\n])\n\nconst filteredSessions = computed(() => {\n  return sessions.value.filter(session => {\n    const matchesSearch = session.title.toLowerCase().includes(searchQuery.value.toLowerCase()) ||\n                        session.preview.toLowerCase().includes(searchQuery.value.toLowerCase())\n    const matchesAgent = !filterAgent.value || session.agentId === filterAgent.value\n    return matchesSearch && matchesAgent\n  })\n})\n\nconst createNewSession = () => {\n  router.push('/session-create')\n}\n\nconst openSession = (sessionKey) => {\n  router.push(`/session/${encodeURIComponent(sessionKey)}`)\n}\n\nconst deleteSession = async (sessionKey) => {\n  if (confirm('确定要删除这个会话吗？')) {\n    const index = sessions.value.findIndex(s => s.key === sessionKey)\n    if (index > -1) {\n      sessions.value.splice(index, 1)\n      // TODO: 调用 Gateway API 删除会话\n    }\n  }\n}\n\nonMounted(() => {\n  // TODO: 从 Gateway API 获取会话列表\n})\n</script>\n\n<style scoped>\n.sessions {\n  max-width: 1200px;\n  margin: 0 auto;\n}\n\n.page-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 24px;\n}\n\n.page-header h1 {\n  font-size: 28px;\n  font-weight: 700;\n  color: white;\n  margin: 0;\n}\n\n.btn-primary {\n  padding: 12px 24px;\n  background: linear-gradient(135deg, #E60012, #ff3366);\n  border: none;\n  border-radius: 8px;\n  color: white;\n  font-size: 14px;\n  font-weight: 600;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  box-shadow: 0 4px 16px rgba(230, 0, 18, 0.3);\n}\n\n.btn-primary:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 6px 24px rgba(230, 0, 18, 0.4);\n}\n\n.sessions-filters {\n  display: flex;\n  gap: 12px;\n  margin-bottom: 24px;\n}\n\n.search-input {\n  flex: 1;\n  padding: 12px 16px;\n  background: rgba(255, 255, 255, 0.08);\n  border: 1px solid rgba(255, 255, 255, 0.15);\n  border-radius: 8px;\n  color: white;\n  font-size: 14px;\n  outline: none;\n  transition: all 0.3s ease;\n}\n\n.search-input::placeholder {\n  color: rgba(255, 255, 255, 0.5);\n}\n\n.search-input:focus {\n  border-color: #E60012;\n  box-shadow: 0 0 0 3px rgba(230, 0, 18, 0.2);\n}\n\n.filter-select {\n  padding: 12px 16px;\n  background: rgba(255, 255, 255, 0.08);\n  border: 1px solid rgba(255, 255, 255, 0.15);\n  border-radius: 8px;\n  color: white;\n  font-size: 14px;\n  cursor: pointer;\n  outline: none;\n}\n\n.filter-select:focus {\n  border-color: #E60012;\n  box-shadow: 0 0 0 3px rgba(230, 0, 18, 0.2);\n}\n\n.loading {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  min-height: 400px;\n}\n\n.spinner {\n  width: 50px;\n  height: 50px;\n  border: 3px solid rgba(255, 255, 255, 0.3);\n  border-top: 3px solid #E60012;\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n}\n\n@keyframes spin {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n\n.sessions-list {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.session-item {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  padding: 16px;\n  background: rgba(255, 255, 255, 0.08);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-radius: 12px;\n  transition: all 0.3s ease;\n}\n\n.session-item:hover {\n  background: rgba(255, 255, 255, 0.12);\n  border-color: rgba(255, 255, 255, 0.2);\n}\n\n.session-item.active {\n  border-color: rgba(230, 0, 18, 0.5);\n  box-shadow: 0 4px 20px rgba(230, 0, 18, 0.15);\n}\n\n.session-main {\n  flex: 1;\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  cursor: pointer;\n}\n\n.session-icon {\n  font-size: 36px;\n  min-width: 48px;\n  height: 48px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 10px;\n}\n\n.session-content {\n  flex: 1;\n  min-width: 0;\n}\n\n.session-header {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  margin-bottom: 6px;\n}\n\n.session-title {\n  font-size: 16px;\n  font-weight: 600;\n  color: white;\n}\n\n.session-agent {\n  padding: 2px 8px;\n  border-radius: 4px;\n  background: rgba(230, 0, 18, 0.2);\n  font-size: 12px;\n  font-weight: 500;\n  color: white;\n}\n\n.session-preview {\n  font-size: 13px;\n  color: rgba(255, 255, 255, 0.6);\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  margin-bottom: 8px;\n}\n\n.session-meta {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  font-size: 12px;\n  color: rgba(255, 255, 255, 0.5);\n}\n\n.session-time {\n  flex: 1;\n}\n\n.unread-badge {\n  min-width: 20px;\n  height: 20px;\n  padding: 0 6px;\n  border-radius: 10px;\n  backg