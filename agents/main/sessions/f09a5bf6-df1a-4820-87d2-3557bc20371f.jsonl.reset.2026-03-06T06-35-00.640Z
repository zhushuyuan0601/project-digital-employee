{"type":"message","id":"1bdffbab","parentId":"bb10263e","timestamp":"2026-03-06T06:00:55.089Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在让我修改 SessionView.vue 来使用真实的 Gateway WebSocket 连接。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"chatcmpl-tool-9dd14b4589085ab1","name":"write","arguments":{"content":"<template>\n  <div class=\"chat-page\">\n    <div class=\"chat-container\">\n      <div class=\"chat-status\" v-if=\"!gatewayConnected\">\n        <div class=\"status-icon\">⚠️</div>\n        <div class=\"status-text\">\n          <div class=\"status-title\">未连接到 Gateway</div>\n          <div class=\"status-detail\">{{ connectionStatus }}</div>\n        </div>\n        <button class=\"btn-reconnect\" @click=\"reconnect\">重新连接</button>\n      </div>\n\n      <div class=\"chat-main\">\n        <div class=\"chat-messages\" ref=\"messagesContainer\">\n          <div\n            v-for=\"(message, index) in messages\"\n            :key=\"index\"\n            :class=\"['message', message.role]\"\n          >\n            <div v-if=\"message.role === 'assistant'\" class=\"message-avatar\">\n              <div class=\"avatar-icon\">{{ message.icon || '🤖' }}</div>\n            </div>\n            <div class=\"message-content\">\n              <div v-if=\"message.role === 'assistant'\" class=\"message-header\">\n                <span class=\"message-sender\">{{ message.sender || '助手' }}</span>\n                <span class=\"message-time\">{{ message.time }}</span>\n              </div>\n              <div class=\"message-text\" v-html=\"formatMessage(message.content)\"></div>\n              <div v-if=\"message.tool_calls && message.tool_calls.length > 0\" class=\"tool-calls\">\n                <div class=\"tool-calls-title\">🔧 工具调用</div>\n                <div v-for=\"(tool, i) in message.tool_calls\" :key=\"i\" class=\"tool-call\">\n                  <span class=\"tool-name\">{{ tool.name }}</span>\n                  <span v-if=\"tool.output\" class=\"tool-output\">{{ tool.output }}</span>\n                </div>\n              </div>\n            </div>\n          </div>\n          \n          <div v-if=\"isSending\" class=\"message assistant\">\n            <div class=\"message-avatar\">\n              <div class=\"avatar-icon\">🤖</div>\n            </div>\n            <div class=\"message-content\">\n              <div class=\"typing-indicator\">\n                <span></span><span></span><span></span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"chat-input-container\">\n          <div class=\"chat-toolbar\">\n            <button class=\"btn-tool\" @click=\"attachFile\" title=\"上传文件\">📎</button>\n            <button class=\"btn-tool\" @click=\"voiceInput\" title=\"语音输入\">🎤</button>\n            <button class=\"btn-tool\" @click=\"insertCode\" title=\"插入代码\">💻</button>\n            <button class=\"btn-tool\" @click=\"toggleThinking\" title=\"思考模式\" :class=\"{ active: thinkingEnabled }\">\n              🧠\n            </button>\n            <button class=\"btn-tool\" @click=\"clearChat\" title=\"清空对话\" v-if=\"messages.length > 2\">🗑️</button>\n          </div>\n          <div class=\"chat-input\">\n            <textarea\n              v-model=\"inputMessage\"\n              placeholder=\"输入消息... (Shift+Enter 换行)\"\n              @keydown=\"handleKeydown\"\n              ref=\"inputRef\"\n              rows=\"1\"\n            ></textarea>\n            <button\n              :class=\"['btn-send', { disabled: !inputMessage.trim() || isSending || !gatewayConnected }]\"\n              @click=\"sendMessage\"\n              :disabled=\"!inputMessage.trim() || isSending || !gatewayConnected\"\n            >\n              <span v-if=\"isSending\">⏳</span>\n              <span v-else>发送</span>\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, computed, onMounted, onUnmounted } from 'vue'\nimport { useRoute, useRouter } from 'vue-router'\nimport { createGatewayClient } from '@/utils/gateway.js'\n\nconst route = useRoute()\nconst router = useRouter()\n\nconst inputMessage = ref('')\nconst isSending = ref(false)\nconst thinkingEnabled = ref(false)\nconst gatewayConnected = ref(false)\nconst connectionStatus = ref('正在连接...')\nconst messages = ref([])\nconst currentRunId = ref(null)\nconst incomingStream = ref('')\n\n// 引用\nconst messagesContainer = ref(null)\nconst inputRef = ref(null)\n\n// Gateway 客户端\nlet gatewayClient = null\n\n// 方法\nconst handleKeydown = (e) => {\n  if (e.key === 'Enter' && !e.shiftKey) {\n    e.preventDefault()\n    sendMessage()\n  }\n}\n\nconst sendMessage = async () => {\n  if (!inputMessage.value.trim() || isSending.value || !gatewayConnected.value) return\n\n  const content = inputMessage.value.trim()\n  inputMessage.value = ''\n\n  // 添加用户消息\n  messages.value.push({\n    role: 'user',\n    content,\n    time: new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })\n  })\n\n  scrollToBottom()\n\n  // 发送消息到 Gateway\n  isSending.value = true\n  incomingStream.value = ''\n\n  try {\n    const response = await gatewayClient.request('chat.send', {\n      sessionKey: getSessionKey(),\n      message: content,\n      deliver: false\n    })\n\n    currentRunId.value = response.id\n\n  } catch (error) {\n    console.error('Send message failed:', error)\n    isSending.value = false\n    messages.value.push({\n      role: 'assistant',\n      content: `❌ 发送失败: ${error.message}\\n\\n${error.details || ''}`,\n      sender: '系统',\n      icon: '⚠️',\n      time: new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })\n    })\n    scrollToBottom()\n  }\n}\n\nconst getSessionKey = () => {\n  return route.params.id || 'agent:main:main'\n}\n\nconst handleGatewayEvent = (event, payload) => {\n  console.log('[Gateway] Event:', event, payload)\n\n  if (event === 'chat') {\n    handleChatEvent(payload)\n  } else if (event === 'connect' || event === 'hello') {\n    // 连接确认\n    gatewayConnected.value = true\n    connectionStatus.value = '已连接'\n    loadHistory()\n  }\n}\n\nconst handleChatEvent = (payload) => {\n  const runId = payload.runId\n  const state = payload.state\n  const message = payload.message\n\n  // 检查是否是当前对话\n  if (payload.sessionKey !== getSessionKey()) {\n    return\n  }\n\n  if (state === 'delta') {\n    // 流式响应\n    const content = message?.text || ''\n    if (content && content.length >= (incomingStream.value || '').length) {\n      incomingStream.value = content\n    }\n  } else if (state === 'final') {\n    // 最终响应\n    isSending.value = false\n\n    if (message) {\n      const assistantMessage = {\n        role: 'assistant',\n        content: '',\n        sender: '助手',\n        icon: '🤖',\n        time: new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })\n      }\n\n      // 提取文本内容\n      if (message.text) {\n        assistantMessage.content = message.text\n      } else if (Array.isArray(message.content)) {\n        const textContent = message.content.find(c => c.type === 'text')\n        if (textContent) {\n          assistantMessage.content = textContent.text\n        }\n      }\n\n      // 提取工具调用\n      if (message.toolCalls && message.toolCalls.length > 0) {\n        assistantMessage.tool_calls = message.toolCalls\n      }\n\n      messages.value.push(assistantMessage)\n    }\n\n    currentRunId.value = null\n    incomingStream.value = ''\n    scrollToBottom()\n  } else if (state === 'error') {\n    isSending.value = false\n    currentRunId.value = null\n    incomingStream.value = ''\n\n    const errorMessage = payload.errorMessage || '发生错误'\n    messages.value.push({\n      role: 'assistant',\n      content: `❌ ${errorMessage}`,\n      sender: '系统',\n      icon: '⚠️',\n      time: new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })\n    })\n    scrollToBottom()\n  } else if (state === 'aborted') {\n    isSending.value = false\n    currentRunId.value = null\n    incomingStream.value = ''\n    scrollToBottom()\n  }\n}\n\nconst loadHistory = async () => {\n  try {\n    const response = await gatewayClient.request('chat.history', {\n      sessionKey: getSessionKey(),\n      limit: 100\n    })\n\n    if (response && response.messages) {\n      messages.value = response.messages.map(msg => ({\n        role: msg.role,\n        content: msg.text || (Array.isArray(msg.content) ? msg.content.filter(c => c.type === 'text').map(c => c.text).join('\\n') : ''),\n        sender: msg.role === 'assistant' ? '助手' : undefined,\n        time: new Date(msg.timestamp || Date.now()).toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })\n      }))\n\n      // 如果没有消息，添加欢迎消息\n      if (messages.value.length === 0) {\n        messages.value.push({\n          role: 'assistant',\n          content: `你好！欢迎来到 OpenClaw 聊天界面 🎉\\n\\n我可以帮你：\\n• 执行命令和脚本\\n• 读写文件\\n• 搜索信息\\n• 分析代码\\n• 等等...\\n\\n请发送消息开始对话！`,\n          sender: 'OpenClaw',\n          icon: '🤖',\n          time: new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })\n        })\n      }\n\n      scrollToBottom()\n    }\n  } catch (error) {\n    console.error('Load history failed:', error)\n  }\n}\n\nconst scrollToBottom = () => {\n  setTimeout(() => {\n    if (messagesContainer.value) {\n      messagesContainer.value.scrollTop = messagesContainer.value.scrollHeight\n    }\n  }, 50)\n}\n\nconst formatMessage = (content) => {\n  if (!content) return ''\n  return content\n    .replace(/\\n/g, '<br>')\n    .replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>')\n    .replace(/`([^`]+)`/g, '<code class=\"inline-code\">$1</code>')\n    .replace(/```([\\s\\S]*?)```/g, '<pre class=\"code-block\"><code>$1</code></pre>')\n}\n\nconst attachFile = () => {\n  alert('文件上传功能开发中...')\n}\n\nconst voiceInput = () => {\n  alert('语音输入功能开发中...')\n}\n\nconst insertCode = () => {\n  inputMessage.value += '\\n```\\n\\n```\\n'\n  inputRef.value?.focus()\n}\n\nconst toggleThinking = () => {\n  thinkingEnabled.value = !thinkingEnabled.value\n}\n\nconst clearChat = () => {\n  if (confirm('确定要清空对话吗？')) {\n    messages.value = []\n  }\n}\n\nconst reconnect = () => {\n  connectionStatus.value = '重新连接中...'\n  gatewayClient.disconnect()\n  \n  setTimeout(() => {\n    gatewayClient.connect()\n  }, 500)\n}\n\n// 生命周期\nonMounted(() => {\n  // 创建 Gateway 客户端\n  const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws'\n  const host = window.location.host\n  const gatewayUrl = `${protocol}://${host}`\n\n  gatewayClient = createGatewayClient({\n    url: gatewayUrl,\n    onConnect: () => {\n      console.log('[Chat] Gateway connected')\n    },\n    onClose: ({ code, reason }) => {\n      gatewayConnected.value = false\n      connectionStatus.value = `连接断开 (${code}): ${reason || '未知原因'}`\n    },\n    onEvent: handleGatewayEvent\n  })\n\n  // 聚焦输入框\n  if (inputRef.value) {\n    inputRef.value.focus()\n  }\n})\n\nonUnmounted(() => {\n  if (gatewayClient) {\n    gatewayClient.disconnect()\n  }\n})\n</script>\n\n<style scoped src=\"@/views/SessionView.vue?style\"></style>","path":"/Users/lihzz/.openclaw/workspace/unicom-ui/src/views/SessionView.vue"}}],"api":"openai-completions","provider":"local-qwen3","model":"GLM-4.7-FP8","usage":{"input":128632,"output":2717,"cacheRead":0,"cacheWrite":0,"totalTokens":131349,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772776773675}}
