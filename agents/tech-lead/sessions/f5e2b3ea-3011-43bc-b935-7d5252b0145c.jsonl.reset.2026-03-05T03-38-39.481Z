{"type":"message","id":"8a12ce4d","parentId":"6c6ffbe2","timestamp":"2026-03-05T02:53:07.895Z","message":{"role":"toolResult","toolCallId":"tool-a20223eb9b564f669c3b62f18bf6dbe1","toolName":"read","content":[{"type":"text","text":"\"\"\"\n爬虫基类\n\"\"\"\nimport asyncio\nimport random\nimport logging\nfrom abc import ABC, abstractmethod\nfrom typing import List, Dict, Any, Optional\nfrom playwright.async_api import async_playwright, Page, Browser\nfrom bs4 import BeautifulSoup\nfrom datetime import datetime\n\nfrom config.config import CRAWL_CONFIG\nfrom ..database.models import Article\n\nlogger = logging.getLogger(__name__)\n\n\nclass BaseCrawler(ABC):\n    \"\"\"爬虫基类\"\"\"\n\n    def __init__(self, source_name: str, base_url: str):\n        self.source_name = source_name\n        self.base_url = base_url\n        self.headers = CRAWL_CONFIG[\"headers\"]\n        self.timeout = CRAWL_CONFIG[\"timeout\"]\n        self.delay_range = CRAWL_CONFIG[\"delay\"]\n\n    @abstractmethod\n    async def crawl(self, limit: int = 20) -> List[Article]:\n        \"\"\"爬取文章列表\n\n        Args:\n            limit: 最多爬取数量\n\n        Returns:\n            文章列表\n        \"\"\"\n        pass\n\n    @abstractmethod\n    def parse_article_list(self, html: str) -> List[Dict[str, Any]]:\n        \"\"\"解析文章列表页\n\n        Args:\n            html: HTML 内容\n\n        Returns:\n            文章信息列表\n        \"\"\"\n        pass\n\n    async def crawl_article_detail(self, url: str) -> Optional[str]:\n        \"\"\"爬取文章详情\n\n        Args:\n            url: 文章 URL\n\n        Returns:\n            文章内容摘要\n        \"\"\"\n        try:\n            async with async_playwright() as p:\n                browser = await p.chromium.launch(headless=True)\n                page = await browser.new_page()\n\n                await page.goto(url, timeout=self.timeout * 1000)\n                await self.random_delay()\n\n                html = await page.content()\n                content = self.parse_article_detail(html)\n\n                await browser.close()\n                return content\n\n        except Exception as e:\n            logger.error(f\"爬取文章详情失败 {url}: {e}\")\n            return None\n\n    def parse_article_detail(self, html: str) -> Optional[str]:\n        \"\"\"解析文章详情页\n\n        Args:\n            html: HTML 内容\n\n        Returns:\n            文章内容摘要\n        \"\"\"\n        soup = BeautifulSoup(html, 'lxml')\n\n        # 子类需要实现具体的提取逻辑\n        # 这里提供一个默认实现，提取段落文本\n        paragraphs = soup.find_all('p')\n        content = ' '.join([p.get_text(strip=True) for p in paragraphs[:10]])\n\n        return content if content else None\n\n    async def random_delay(self):\n        \"\"\"随机延迟\"\"\"\n        delay = random.uniform(*self.delay_range)\n        await asyncio.sleep(delay)\n\n    def parse_datetime(self, time_str: str) -> Optional[datetime]:\n        \"\"\"解析时间字符串\n\n        Args:\n            time_str: 时间字符串\n\n        Returns:\n            datetime 对象\n        \"\"\"\n        # 子类可以重写这个方法\n        try:\n            from dateutil import parser\n            return parser.parse(time_str)\n        except Exception as e:\n            logger.debug(f\"时间解析失败: {e}\")\n            return None\n\n    def clean_text(self, text: str) -> str:\n        \"\"\"清理文本\n\n        Args:\n            text: 原始文本\n\n        Returns:\n            清理后的文本\n        \"\"\"\n        if not text:\n            return \"\"\n\n        # 移除多余空格和换行\n        text = ' '.join(text.split())\n        return text.strip()"}],"isError":false,"timestamp":1772679187891}}
{"type":"message","id":"e5842c27","parentId":"8a12ce4d","timestamp":"2026-03-05T02:53:07.906Z","message":{"role":"toolResult","toolCallId":"tool-5848ed6f5dae4676a48dd284a1d31d42","toolName":"read","content":[{"type":"text","text":"\"\"\"\n机器之心爬虫\n\"\"\"\nimport logging\nfrom typing import List, Dict, Any, Optional\nfrom playwright.async_api import async_playwright\nfrom datetime import datetime\nfrom bs4 import BeautifulSoup\nfrom dateutil import parser as date_parser\n\nfrom .base_crawler import BaseCrawler\nfrom ..database.models import Article\n\nlogger = logging.getLogger(__name__)\n\n\nclass JiqizhixinCrawler(BaseCrawler):\n    \"\"\"机器之心爬虫\"\"\"\n\n    def __init__(self):\n        super().__init__(\"机器之心\", \"https://www.jiqizhixin.com\")\n        self.article_list_url = \"https://www.jiqizhixin.com/ai\"\n\n    async def crawl(self, limit: int = 20) -> List[Article]:\n        \"\"\"爬取机器之心文章列表\"\"\"\n        logger.info(f\"开始爬取 {self.source_name}，目标数量: {limit}\")\n\n        try:\n            async with async_playwright() as p:\n                browser = await p.chromium.launch(headless=True)\n                page = await browser.new_page()\n\n                # 设置 User-Agent\n                await page.set_extra_http_headers({\n                    \"User-Agent\": self.headers[\"User-Agent\"]\n                })\n\n                # 访问文章列表页\n                logger.info(f\"访问 {self.article_list_url}\")\n                await page.goto(self.article_list_url, timeout=self.timeout * 1000)\n                await self.random_delay()\n\n                # 获取 HTML\n                html = await page.content()\n                articles_info = self.parse_article_list(html)\n\n                logger.info(f\"解析到 {len(articles_info)} 篇文章\")\n\n                # 爬取文章详情（限制数量）\n                articles = []\n                count = 0\n                for info in articles_info[:limit]:\n                    await self.random_delay()\n\n                    # 爬取文章详情\n                    detail_url = info.get(\"url\")\n                    if detail_url:\n                        logger.info(f\"爬取文章详情: {info['title'][:30]}...\")\n                        content = await self.crawl_article_detail_by_page(browser, detail_url)\n\n                        article = Article(\n                            title=info[\"title\"],\n                            url=detail_url,\n                            source=self.source_name,\n                            content=content,\n                            published_at=info.get(\"published_at\"),\n                            crawled_at=datetime.now(),\n                            status=\"new\"\n                        )\n\n                        articles.append(article)\n                        count += 1\n\n                        if count >= limit:\n                            break\n\n                await browser.close()\n                logger.info(f\"成功爬取 {len(articles)} 篇文章\")\n                return articles\n\n        except Exception as e:\n            logger.error(f\"爬取 {self.source_name} 失败: {e}\")\n            return []\n\n    def parse_article_list(self, html: str) -> List[Dict[str, Any]]:\n        \"\"\"解析文章列表页\"\"\"\n        articles = []\n        soup = BeautifulSoup(html, 'lxml')\n\n        # 机器之心的文章列表结构\n        # 根据实际网页结构调整选择器\n        article_items = soup.select('.article-item, .article-card, article[itemtype=\"http://schema.org/Article\"]')\n\n        if not article_items:\n            logger.warning(\"未找到文章列表，尝试其他选择器...\")\n            # 尝试其他可能的选择器\n            article_items = soup.find_all('a', href=lambda x: x and x.startswith('/article'))\n\n        logger.info(f\"找到 {len(article_items)} 个文章元素\")\n\n        for item in article_items:\n            try:\n                # 提取标题\n                title_elem = item.select_one('h2, h3, .title, .article-title')\n                if not title_elem:\n                    # 尝试直接从 a 标签提取\n                    link_elem = item.select_one('a[href]')\n                    if link_elem:\n                        title_elem = link_elem\n\n                if title_elem:\n                    title = title_elem.get_text(strip=True)\n                else:\n                    continue\n\n                # 提取链接\n                link_elem = item.select_one('a[href]') or title_elem\n                if not link_elem:\n                    continue\n\n                url = link_elem.get('href', '')\n                if url.startswith('/'):\n                    url = self.base_url + url\n\n                # 提取时间\n                time_elem = item.select_one('.time, .date, .article-time, time')\n                published_at = None\n                if time_elem:\n                    time_text = time_elem.get_text(strip=True)\n                    published_at = self.parse_datetime(time_text)\n\n                # 简单的摘要\n                summary_elem = item.select_one('.summary, .excerpt, .description')\n                content = summary_elem.get_text(strip=True) if summary_elem else title\n\n                articles.append({\n                    \"title\": title,\n                    \"url\": url,\n                    \"published_at\": published_at,\n                    \"content\": content\n                })\n\n            except Exception as e:\n                logger.debug(f\"解析文章元素失败: {e}\")\n                continue\n\n        return articles\n\n    async def crawl_article_detail_by_page(self, browser, url: str) -> Optional[str]:\n        \"\"\"使用已有的 page 对象爬取文章详情\"\"\"\n        try:\n            page = await browser.new_page()\n            await page.goto(url, timeout=self.timeout * 1000)\n            await self.random_delay()\n\n            html = await page.content()\n            content = self.parse_article_detail(html)\n\n            await page.close()\n            return content\n\n        except Exception as e:\n            logger.error(f\"爬取文章详情失败 {url}: {e}\")\n            return None\n\n    def parse_article_detail(self, html: str) -> Optional[str]:\n        \"\"\"解析文章详情页\"\"\"\n        soup = BeautifulSoup(html, 'lxml')\n\n        # 尝试多种选择器提取正文\n        content_selectors = [\n            'article .content',\n            '.article-content',\n            'article .post-content',\n            '.post-body',\n            'article',\n            '#article-content'\n        ]\n\n        content_elem = None\n        for selector in content_selectors:\n            content_elem = soup.select_one(selector)\n            if content_elem:\n                break\n\n        if not content_elem:\n            logger.warning(\"未找到文章内容，使用 p 标签提取\")\n            # 提取前 10 个 p 标签\n            paragraphs = soup.find_all('p', limit=15)\n            content = ' '.join([p.get_text(strip=True) for p in paragraphs])\n        else:\n            # 提取段落文本\n            paragraphs = content_elem.find_all('p', limit=15)\n            content = ' '.join([p.get_text(strip=True) for p in paragraphs])\n\n        # 清理文本\n        content = self.clean_text(content)\n\n        return content if content and len(content) > 50 else None\n\n    def parse_datetime(self, time_str: str) -> Optional[datetime]:\n        \"\"\"解析时间字符串（机器之心特化）\"\"\"\n        if not time_str:\n            return None\n\n        try:\n            # 相对时间处理（如 \"2小时前\"）\n            if \"小时前\" in time_str:\n                hours = int(time_str.replace(\"小时前\", \"\"))\n                return datetime.now().replace(minute=0, second=0, microsecond=0)\n            elif \"天前\" in time_str:\n                days = int(time_str.replace(\"天前\", \"\"))\n                return datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)\n\n            # 绝对时间\n            return date_parser.parse(time_str)\n\n        except Exception as e:\n            logger.debug(f\"时间解析失败: {time_str}, {e}\")\n            return datetime.now()  # 默认返回当前时间"}],"isError":false,"timestamp":1772679187901}}
