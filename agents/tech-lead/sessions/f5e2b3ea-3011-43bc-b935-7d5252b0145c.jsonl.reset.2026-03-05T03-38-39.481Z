one('a[href]') or title_elem\n                if not link_elem:\n                    continue\n\n                url = link_elem.get('href', '')\n                if url.startswith('/'):\n                    url = self.base_url + url\n                elif not url.startswith('http'):\n                    url = self.base_url + '/' + url\n\n                # 提取时间\n                time_elem = item.select_one('.time, .date, .newsflash-time, time')\n                published_at = None\n                if time_elem:\n                    time_text = time_elem.get_text(strip=True)\n                    published_at = self.parse_datetime(time_text)\n\n                # 摘要\n                summary_elem = item.select_one('.summary, .description, .newsflash-content')\n                content = summary_elem.get_text(strip=True) if summary_elem else title\n\n                articles.append({\n                    \"title\": title,\n                    \"url\": url,\n                    \"published_at\": published_at,\n                    \"content\": content\n                })\n\n            except Exception as e:\n                logger.debug(f\"解析文章元素失败: {e}\")\n                continue\n\n        return articles","newText":"def parse_article_list(self, html: str) -> List[Dict[str, Any]]:\n        \"\"\"解析文章列表页\"\"\"\n        articles = []\n        soup = BeautifulSoup(html, 'lxml')\n\n        # 36氪的新闻快讯实际结构：直接查找所有新闻快讯链接\n        # 网站使用 /newsflashes/{ID} 格式的链接\n        article_items = soup.find_all('a', href=lambda x: x and '/newsflashes/' in str(x))\n\n        logger.info(f\"找到 {len(article_items)} 个文章链接\")\n\n        for item in article_items:\n            try:\n                # 标题直接在链接文本中\n                title = item.get_text(strip=True)\n                \n                # 跳过空标题或太短的标题\n                if not title or len(title) < 5:\n                    continue\n\n                # 提取链接\n                url = item.get('href', '')\n                if url.startswith('/'):\n                    url = self.base_url + url\n                elif not url.startswith('http'):\n                    url = self.base_url + '/' + url\n\n                # 提取时间：查找相邻的时间元素\n                # 时间通常在链接附近的文本中，格式如\"03月05\"\n                published_at = None\n                parent = item.parent\n                if parent:\n                    # 查找时间文本\n                    time_text = parent.get_text()\n                    import re\n                    time_match = re.search(r'(\\d{2}月\\d{2})', time_text)\n                    if time_match:\n                        time_str = time_match.group(1)\n                        # 转换为日期格式\n                        try:\n                            month = time_str.split('月')[0]\n                            day = time_str.split('月')[1]\n                            year = datetime.now().year\n                            published_at = datetime(year, int(month), int(day))\n                        except:\n                            published_at = datetime.now()\n\n                # 内容默认使用标题\n                content = title\n\n                articles.append({\n                    \"title\": title,\n                    \"url\": url,\n                    \"published_at\": published_at or datetime.now(),\n                    \"content\": content\n                })\n\n                logger.debug(f\"解析成功: {title[:30]}...\")\n\n            except Exception as e:\n                logger.debug(f\"解析文章元素失败: {e}\")\n                continue\n\n        logger.info(f\"成功解析 {len(articles)} 篇文章\")\n        return articles"}}],"api":"openai-completions","provider":"alibaba","model":"glm-5","usage":{"input":434,"output":1340,"cacheRead":105983,"cacheWrite":0,"totalTokens":107757,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772679363075}}
{"type":"message","id":"06199441","parentId":"1028b22e","timestamp":"2026-03-05T02:57:06.745Z","message":{"role":"toolResult","toolCallId":"tool-e63c3a9df0324b40b699f6ed31b34ee2","toolName":"read","content":[{"type":"text","text":"\"\"\"\n36氪爬虫\n\"\"\"\nimport logging\nfrom typing import List, Dict, Any, Optional\nfrom datetime import datetime\nfrom bs4 import BeautifulSoup\nfrom dateutil import parser as date_parser\nfrom playwright.async_api import async_playwright\n\nfrom .base_crawler import BaseCrawler\nfrom ..database.models import Article\n\nlogger = logging.getLogger(__name__)\n\n\nclass Kr36Crawler(BaseCrawler):\n    \"\"\"36氪爬虫\"\"\"\n\n    def __init__(self):\n        super().__init__(\"36氪\", \"https://36kr.com\")\n        self.article_list_url = \"https://36kr.com/newsflashes\"\n\n    async def crawl(self, limit: int = 20) -> List[Article]:\n        \"\"\"爬取36氪文章列表\"\"\"\n        logger.info(f\"开始爬取 {self.source_name}，目标数量: {limit}\")\n\n        try:\n            async with async_playwright() as p:\n                browser = await p.chromium.launch(headless=True)\n                page = await browser.new_page()\n\n                await page.set_extra_http_headers({\n                    \"User-Agent\": self.headers[\"User-Agent\"]\n                })\n\n                logger.info(f\"访问 {self.article_list_url}\")\n                await page.goto(self.article_list_url, timeout=self.timeout * 1000)\n                await self.random_delay()\n\n                html = await page.content()\n                articles_info = self.parse_article_list(html)\n\n                logger.info(f\"解析到 {len(articles_info)} 篇文章\")\n\n                articles = []\n                count = 0\n                for info in articles_info[:limit]:\n                    await self.random_delay()\n\n                    detail_url = info.get(\"url\")\n                    if detail_url:\n                        logger.info(f\"爬取文章详情: {info['title'][:30]}...\")\n                        content = await self.crawl_article_detail_by_page(browser, detail_url)\n\n                        article = Article(\n                            title=info[\"title\"],\n                            url=detail_url,\n                            source=self.source_name,\n                            content=content,\n                            published_at=info.get(\"published_at\"),\n                            crawled_at=datetime.now(),\n                            status=\"new\"\n                        )\n\n                        articles.append(article)\n                        count += 1\n\n                        if count >= limit:\n                            break\n\n                await browser.close()\n                logger.info(f\"成功爬取 {len(articles)} 篇文章\")\n                return articles\n\n        except Exception as e:\n            logger.error(f\"爬取 {self.source_name} 失败: {e}\")\n            return []\n\n    def parse_article_list(self, html: str) -> List[Dict[str, Any]]:\n        \"\"\"解析文章列表页\"\"\"\n        articles = []\n        soup = BeautifulSoup(html, 'lxml')\n\n        # 36氪的新闻快讯结构\n        article_items = soup.select('.newsflash-item, .article-item, .item')\n\n        if not article_items:\n            logger.warning(\"未找到文章列表，尝试其他选择器...\")\n            article_items = soup.find_all('a', href=lambda x: x and '/news/' in str(x))\n\n        logger.info(f\"找到 {len(article_items)} 个文章元素\")\n\n        for item in article_items:\n            try:\n                # 提取标题\n                title_elem = item.select_one('a.title, .newsflash-title, h2, h3')\n                if not title_elem:\n                    link_elem = item.select_one('a[href]')\n                    if link_elem:\n                        title_elem = link_elem\n\n                if title_elem:\n                    title = title_elem.get_text(strip=True)\n                else:\n                    continue\n\n                # 提取链接\n                link_elem = item.select_one('a[href]') or title_elem\n                if not link_elem:\n                    continue\n\n                url = link_elem.get('href', '')\n                if url.startswith('/'):\n                    url = self.base_url + url\n                elif not url.startswith('http'):\n                    url = self.base_url + '/' + url\n\n                # 提取时间\n                time_elem = item.select_one('.time, .date, .newsflash-time, time')\n                published_at = None\n                if time_elem:\n                    time_text = time_elem.get_text(strip=True)\n                    published_at = self.parse_datetime(time_text)\n\n                # 摘要\n                summary_elem = item.select_one('.summary, .description, .newsflash-content')\n                content = summary_elem.get_text(strip=True) if summary_elem else title\n\n                articles.append({\n                    \"title\": title,\n                    \"url\": url,\n                    \"published_at\": published_at,\n                    \"content\": content\n                })\n\n            except Exception as e:\n                logger.debug(f\"解析文章元素失败: {e}\")\n                continue\n\n        return articles\n\n    async def crawl_article_detail_by_page(self, browser, url: str) -> Optional[str]:\n        \"\"\"使用已有的 page 对象爬取文章详情\"\"\"\n        try:\n            page = await browser.new_page()\n            await page.goto(url, timeout=self.timeout * 1000)\n            await self.random_delay()\n\n            html = await page.content()\n            content = self.parse_article_detail(html)\n\n            await page.close()\n            return content\n\n        except Exception as e:\n            logger.error(f\"爬取文章详情失败 {url}: {e}\")\n            return None\n\n    def parse_article_detail(self, html: str) -> Optional[str]:\n        \"\"\"解析文章详情页\"\"\"\n        soup = BeautifulSoup(html, 'lxml')\n\n        # 尝试多种选择器\n        content_selectors = [\n            '.article-content',\n            '.content',\n            'article',\n            '.post-content'\n        ]\n\n        content_elem = None\n        for selector in content_selectors:\n            content_elem = soup.select_one(selector)\n            if content_elem:\n                break\n\n        if not content_elem:\n            paragraphs = soup.find_all('p', limit=15)\n            content = ' '.join([p.get_text(strip=True) for p in paragraphs])\n        else:\n            paragraphs = content_elem.find_all('p', limit=15)\n            content = ' '.join([p.get_text(strip=True) for p in paragraphs])\n\n        content = self.clean_text(content)\n        return content if content and len(content) > 50 else None\n\n    def parse_datetime(self, time_str: str) -> Optional[datetime]:\n        \"\"\"解析时间字符串\"\"\"\n        if not time_str:\n            return None\n\n        try:\n            if \"小时前\" in time_str:\n                return datetime.now().replace(minute=0, second=0, microsecond=0)\n            elif \"天前\" in time_str:\n                return datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)\n\n            return date_parser.parse(time_str)\n\n        except Exception as e:\n            logger.debug(f\"时间解析失败: {time_str}, {e}\")\n            return datetime.now()"}],"isError":false,"timestamp":1772679426739}}
