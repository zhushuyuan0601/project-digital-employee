{
  "name": "project-digital-employee",
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "analysis:start": "bash ./start-analysis-dev.sh",
    "analysis:stop": "bash ./stop-analysis-dev.sh",
    "dev": "vite --host 0.0.0.0 --port 10001",
    "dev:client": "vite --host 0.0.0.0 --port 10001",
    "dev:server": "PORT=18888 node server/index.js",
    "server": "node server/index.js",
    "build": "vite build",
    "desktop:dev": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder --mac dmg",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "verify": "npm run typecheck && npm run build"
  },
  "build": {
    "appId": "com.project.digitalemployee",
    "productName": "Digital Employee",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!data/runtime-workspaces/**",
          "!data/task-outputs/**",
          "!data/*.db",
          "!data/*.db-shm",
          "!data/*.db-wal"
        ]
      },
      {
        "from": "analysis_service",
        "to": "analysis_service",
        "filter": [
          "**/*",
          "!workspace/**",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "dir"
      ],
      "category": "public.app-category.productivity",
      "identity": null
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "@element-plus/icons-vue": "^2.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@vueuse/core": "^10.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dompurify": "^3.4.1",
    "element-plus": "^2.13.4",
    "express": "^4.22.2",
    "imapflow": "^1.3.3",
    "mailparser": "^3.9.8",
    "markdown-it": "^14.1.1",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "node-pty": "^1.1.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "sass-embedded": "^1.98.0",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "unplugin-element-plus": "^0.11.2",
    "vite": "^5.0.0",
    "vue-tsc": "^3.2.5"
  }
}
