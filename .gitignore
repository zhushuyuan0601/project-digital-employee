# OpenClaw 配置目录 .gitignore

# 敏感凭证文件 - 绝对不要提交！
credentials/
*.pem
*.key
*.token
.env
.env.*

# 缓存和临时文件
*.log
logs/
cache/
*.tmp
*.temp

# 运行时数据
delivery-queue/
completions/

# 系统文件
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# 敏感配置
exec-approvals.json
devices/

# Canvas 临时文件
canvas/

# 备份文件
*.bak
*.bak.*

# 测试文件
TEST-*.md
# 备份文件
*.bak
*.bak.*

# 共享工作区（可选，看用户需求）
# shared-workspace/

# 更新检查
update-check.json
