# Gateway 连接配置
# 用于连接 OpenClaw Gateway 获取实时 Agent 消息

# Gateway 直接连接配置（推荐）
# 直接连接 Gateway，不走 Vite 代理
# 这样 Gateway 能正确识别为本地连接，避免 scopes 被清空
VITE_GATEWAY_HOST=127.0.0.1
VITE_GATEWAY_PORT=18789

# Gateway WebSocket URL（可选，优先级高于 HOST/PORT）
# VITE_GATEWAY_WS_URL=ws://127.0.0.1:18789

# Gateway 认证令牌（必需！从你的 OpenClaw Gateway 获取）
# 获取方式：openclaw gateway token
VITE_GATEWAY_TOKEN=your-gateway-token-here

# Gateway 客户端 ID
VITE_GATEWAY_CLIENT_ID=unicom-mission-control

# ===== 安全配置 =====

# 服务端 API 认证令牌（设置后所有 /api/* 路由需要 Bearer token）
# 不设置则跳过认证（开发模式）
# API_AUTH_TOKEN=your-secret-token-here

# 前端传递给 API 的认证令牌（需与 API_AUTH_TOKEN 一致）
# VITE_API_AUTH_TOKEN=your-secret-token-here

# CORS 允许的源（逗号分隔）
CORS_ORIGIN=http://localhost:5173

# 文件 API 允许访问的根目录（逗号分隔）
# 不设置则允许所有路径（开发模式）
# FILE_ROOTS=~/workspace,~/projects

# 允许 test-connection 访问私有 IP（开发模式下可设为 true）
ALLOW_PRIVATE_URLS=true

# ===== Agent Runtime 配置 =====

# 主 Agent 调度运行时：claude-code 或 openclaw（legacy）
AGENT_RUNTIME=claude-code

# Claude Code 报告型多 Agent 编排
CLAUDE_AGENT_MAX_CONCURRENCY=3
CLAUDE_REPORT_ONLY=true
CLAUDE_RUNTIME_CWD=/Users/lh/git/project-digital-employee
CLAUDE_WORKSPACE_ISOLATION=true
CLAUDE_WORKSPACE_ROOT=server/data/runtime-workspaces
CLAUDE_ALLOWED_TOOLS=Read,Glob,Grep
CLAUDE_OUTPUT_ROOT=server/data/task-outputs

# 开发联调时可设为 true，不调用真实 Claude Code，只生成模拟报告
# CLAUDE_RUNTIME_MOCK=false

# 注意：
# - 通过 Vite 代理 (/ws) 连接时，Gateway 无法正确识别为本地连接
# - 会导致 scopes 被清空，所有操作报 "missing scope" 错误
# - 因此默认使用直接连接方式
